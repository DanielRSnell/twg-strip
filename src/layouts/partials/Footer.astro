---
import ImageMod from "@/components/ImageMod.astro";
import menu from "@/config/menu.json";

const { footer }: { footer: any } = menu;
---

<footer class="relative bg-primary text-white overflow-hidden">
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(60px,1fr)_minmax(0,1200px)_minmax(60px,1fr)]">

    <!-- Left Gutter (patterned) -->
    <div class="hidden lg:block border-r border-white/[0.06] footer-grid"></div>

    <!-- Center Content (solid) -->
    <div class="bg-primary">
      <!-- Main footer content -->
      <div class="grid lg:grid-cols-[2fr_3fr] max-lg:divide-y lg:divide-x divide-white/[0.06]">
        <!-- Left: Logo + info -->
        <div class="py-12 lg:py-16 px-6 lg:px-12">
          <ImageMod
            class="mb-8 w-36 brightness-0 invert"
            src="/images/logo.svg"
            alt="logo"
            width={0}
            height={0}
          />
          <div class="flex items-center mb-6 text-sm text-white/40">
            <a class="pr-2 leading-5 border-r border-white/20 hover:text-white/60 transition-colors" href="http:/thiswayglobal.com">ThisWay</a>
            <p class="pl-2">All rights reserved</p>
          </div>

          <!-- ISO Certifications -->
          <div class="mt-8">
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-white/30">Certifications</p>
            <div class="flex gap-3 items-center">
              <div class="flex items-center justify-center bg-white rounded p-1 shadow-sm">
                <ImageMod
                  class="w-auto h-14"
                  src="/images/certifications/iso/A-LIGN_ISO-27001.png"
                  alt="ISO 27001 Certification"
                  width={0}
                  height={0}
                />
              </div>
              <div class="flex items-center justify-center bg-white rounded p-1 shadow-sm">
                <ImageMod
                  class="w-auto h-14"
                  src="/images/certifications/wbe.webp"
                  alt="WBE Certification"
                  width={0}
                  height={0}
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Navigation -->
        <div class="py-12 lg:py-16 px-6 lg:px-12">
          <div class="grid grid-cols-2 gap-8">
            {
              footer.map((item: { items: any[] }, i: number) => (
                <ul class="flex flex-col gap-4">
                  {item.items.map((item: any) => (
                    <li class="text-sm">
                      <a href={item.url} class="text-white/40 hover:text-white/70 transition-colors">{item.name}</a>
                    </li>
                  ))}
                </ul>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="border-t border-white/[0.06] py-5 px-6 lg:px-12">
        <p class="text-xs text-white/20">&copy; {new Date().getFullYear()} ThisWay Global. Sovereign AI infrastructure.</p>
      </div>
    </div>

    <!-- Right Gutter (patterned) -->
    <div class="hidden lg:block border-l border-white/[0.06] footer-grid"></div>

  </div>
</footer>

<style>
  /* Pattern color inherits currentColor (footer text) so it adapts to any theme flag. */
  .footer-grid {
    color: #fff;
    background-image:
      repeating-linear-gradient(45deg, transparent, transparent 7px, color-mix(in srgb, currentColor 2.5%, transparent) 7px, color-mix(in srgb, currentColor 2.5%, transparent) 8px),
      repeating-linear-gradient(-45deg, transparent, transparent 7px, color-mix(in srgb, currentColor 1.2%, transparent) 7px, color-mix(in srgb, currentColor 1.2%, transparent) 8px);
  }
</style>
