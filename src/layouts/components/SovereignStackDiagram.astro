---
// Sovereign AI Stack diagram
// Amalgamy as the unified operating layer between the workloads it runs
// and the existing environments + infrastructure it orchestrates.
// Side rails frame the Blueprint motion (left) and governance scope (right).
const gridSvg =
  "url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cpath d=%22M0 30h60M30 0v60%22 stroke=%22%23fff%22 stroke-width=%220.5%22 fill=%22none%22/%3E%3C/svg%3E')";
---

<div class="relative overflow-hidden rounded-xl border border-white/10 bg-gradient-to-br from-[#0c1320] via-[#111d30] to-[#0c1320] px-4 py-8 sm:px-8 sm:py-10 lg:px-12">
  <!-- Grid texture -->
  <div class="absolute inset-0 opacity-[0.05]" style={`background-image: ${gridSvg};`}></div>
  <!-- Brand glow behind the Amalgamy layer -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[420px] h-[260px] rounded-full bg-brand/10 blur-3xl pointer-events-none"></div>

  <div class="relative z-10">
    <!-- Caption -->
    <p class="mx-auto max-w-xl text-center text-sm leading-relaxed text-white/70 sm:text-base">
      Amalgamy unifies AI and HPC operations across the sovereign AI stack.
    </p>
    <p class="mt-2 text-center text-[10px] font-semibold uppercase tracking-[0.25em] text-brand/70 sm:text-xs">
      Sovereign AI Blueprint
    </p>

    <!-- Rails (mobile: horizontal labels above the stack) -->
    <div class="mt-5 flex flex-wrap justify-center gap-x-5 gap-y-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-white/35 lg:hidden">
      <span>Plan &bull; Build &bull; Activate</span>
      <span>Policy &bull; Governance &bull; Workforce Enablement</span>
    </div>

    <!-- Stack with side rails -->
    <div class="mt-6 flex items-stretch gap-3 lg:mt-8 lg:gap-5">
      <!-- Left rail (desktop) -->
      <div class="hidden items-center justify-center lg:flex">
        <span class="whitespace-nowrap text-[11px] font-semibold uppercase tracking-[0.3em] text-white/35 [writing-mode:vertical-rl] rotate-180">
          Plan &bull; Build &bull; Activate
        </span>
      </div>

      <!-- Center stack -->
      <div class="flex-1 space-y-3 lg:space-y-3.5">
        <!-- Workloads -->
        <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-4 text-center sm:px-6 sm:py-5" data-aos="fade-up-sm" data-aos-delay="50">
          <div class="text-lg font-bold text-white sm:text-xl lg:text-2xl">Workloads</div>
          <div class="mt-1.5 text-[11px] leading-relaxed text-white/45 sm:text-sm">
            World Models &bull; Model Training &bull; Inference &bull; Agentic Workflows &bull; HPC Jobs
          </div>
        </div>

        <!-- Amalgamy (highlighted operating layer) -->
        <div class="relative rounded-lg border-2 border-brand/50 bg-brand/[0.06] px-4 py-5 text-center shadow-[0_0_40px_rgba(36,171,157,0.15)] sm:px-6 sm:py-6" data-aos="fade-up-sm" data-aos-delay="100">
          <div class="text-2xl font-extrabold text-brand sm:text-3xl lg:text-4xl">Amalgamy</div>
          <div class="mt-1 text-sm font-medium text-white/85 sm:text-base">Unified AI + HPC Operating System</div>
          <div class="mt-1.5 text-[11px] leading-relaxed text-brand/60 sm:text-sm">
            Orchestration &bull; Utilization Intelligence &bull; Access Control &bull; Resource Optimization
          </div>
        </div>

        <!-- Existing Environments -->
        <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-4 text-center sm:px-6 sm:py-5" data-aos="fade-up-sm" data-aos-delay="150">
          <div class="text-lg font-bold text-white sm:text-xl lg:text-2xl">Existing Environments</div>
          <div class="mt-1.5 text-[11px] leading-relaxed text-white/45 sm:text-sm">
            Slurm &bull; Kubernetes &bull; Run:ai &bull; Linux &bull; Cloud &amp; On-Prem Systems
          </div>
        </div>

        <!-- Infrastructure -->
        <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-4 text-center sm:px-6 sm:py-5" data-aos="fade-up-sm" data-aos-delay="200">
          <div class="text-lg font-bold text-white sm:text-xl lg:text-2xl">Infrastructure</div>
          <div class="mt-1.5 text-[11px] leading-relaxed text-white/45 sm:text-sm">
            Facilities &bull; Power &bull; Cooling &bull; GPU/CPU &bull; Storage &bull; Networking
          </div>
        </div>
      </div>

      <!-- Right rail (desktop) -->
      <div class="hidden items-center justify-center lg:flex">
        <span class="whitespace-nowrap text-[11px] font-semibold uppercase tracking-[0.3em] text-white/35 [writing-mode:vertical-rl]">
          Policy &bull; Governance &bull; Workforce Enablement
        </span>
      </div>
    </div>
  </div>
</div>
