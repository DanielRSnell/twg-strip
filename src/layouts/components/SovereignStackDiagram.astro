---
// Sovereign AI Stack diagram
// Amalgamy as the unified operating layer between the workloads it runs
// and the existing environments + infrastructure it orchestrates.
// Side rails frame the Blueprint motion (left) and governance scope (right);
// on mobile they reflow to labels above and below the stack.
const gridSvg =
  "url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cpath d=%22M0 30h60M30 0v60%22 stroke=%22%23fff%22 stroke-width=%220.5%22 fill=%22none%22/%3E%3C/svg%3E')";

// Standard layers (rendered identically); the Amalgamy layer is bespoke.
const layers = [
  {
    name: "Workloads",
    items: "World Models • Model Training • Inference • Agentic Workflows • HPC Jobs",
  },
  {
    name: "Existing Environments",
    items: "Slurm • Kubernetes • Run:ai • Linux • Cloud and On-Prem Systems",
  },
  {
    name: "Infrastructure",
    items: "Facilities • Power • Cooling • GPU/CPU • Storage • Networking",
  },
];

const railLeft = "Plan • Build • Activate";
const railRight = "Policy • Governance • Workforce Enablement";
---

<div class="relative overflow-hidden rounded-xl border border-white/10 bg-primary bg-gradient-to-br from-primary via-[#0d1117] to-primary px-5 py-9 sm:px-8 sm:py-10 lg:px-12">
  <!-- Grid texture -->
  <div class="absolute inset-0 opacity-[0.05]" style={`background-image: ${gridSvg};`}></div>
  <!-- Brand glow behind the Amalgamy layer -->
  <div class="pointer-events-none absolute left-1/2 top-1/2 h-[260px] w-[420px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand/10 blur-3xl"></div>

  <div class="relative z-10">
    <!-- Header -->
    <p class="text-center text-base font-bold uppercase tracking-[0.18em] text-brand sm:text-lg">
      Sovereign AI Blueprint
    </p>
    <!-- Subheader -->
    <p class="mx-auto mt-2 max-w-md text-center text-sm leading-relaxed text-white/60 sm:max-w-xl sm:text-base">
      Amalgamy unifies AI and HPC operations across the sovereign AI stack.
    </p>

    <!-- Top rail label (mobile only) -->
    <p class="mt-7 text-center text-[11px] font-semibold uppercase tracking-[0.22em] text-white/35 lg:hidden">
      {railLeft}
    </p>

    <!-- Stack with side rails -->
    <div class="mt-3 flex items-stretch gap-3 lg:mt-8 lg:gap-5">
      <!-- Left rail (desktop) -->
      <div class="hidden items-center justify-center lg:flex">
        <span class="whitespace-nowrap text-[11px] font-semibold uppercase tracking-[0.3em] text-white/35 [writing-mode:vertical-rl] rotate-180">
          {railLeft}
        </span>
      </div>

      <!-- Center stack -->
      <div class="flex-1 space-y-3.5">
        <!-- Workloads -->
        <div class="rounded-lg border border-white/10 bg-white/[0.03] px-5 py-5 text-center" data-aos="fade-up-sm" data-aos-delay="50">
          <h3 class="text-lg font-bold tracking-tight text-white sm:text-xl lg:text-2xl">{layers[0].name}</h3>
          <p class="mx-auto mt-2 max-w-[40ch] text-xs leading-relaxed text-white/45 [text-wrap:balance] sm:text-sm">
            {layers[0].items}
          </p>
        </div>

        <!-- Amalgamy (highlighted operating layer) -->
        <div class="relative rounded-lg border-2 border-brand/50 bg-brand/[0.06] px-5 py-6 text-center shadow-[0_0_40px_rgba(36,171,157,0.15)]" data-aos="fade-up-sm" data-aos-delay="100">
          <h3 class="text-2xl font-extrabold tracking-tight text-brand sm:text-3xl lg:text-4xl">Amalgamy</h3>
          <p class="mt-1.5 text-sm font-medium text-white/85 sm:text-base">Unified AI + HPC Operating System</p>
          <p class="mx-auto mt-2 max-w-[42ch] text-xs leading-relaxed text-brand/60 [text-wrap:balance] sm:text-sm">
            Orchestration • Utilization Intelligence • Access Control • Resource Optimization
          </p>
        </div>

        <!-- Existing Environments -->
        <div class="rounded-lg border border-white/10 bg-white/[0.03] px-5 py-5 text-center" data-aos="fade-up-sm" data-aos-delay="150">
          <h3 class="text-lg font-bold tracking-tight text-white sm:text-xl lg:text-2xl">{layers[1].name}</h3>
          <p class="mx-auto mt-2 max-w-[40ch] text-xs leading-relaxed text-white/45 [text-wrap:balance] sm:text-sm">
            {layers[1].items}
          </p>
        </div>

        <!-- Infrastructure -->
        <div class="rounded-lg border border-white/10 bg-white/[0.03] px-5 py-5 text-center" data-aos="fade-up-sm" data-aos-delay="200">
          <h3 class="text-lg font-bold tracking-tight text-white sm:text-xl lg:text-2xl">{layers[2].name}</h3>
          <p class="mx-auto mt-2 max-w-[40ch] text-xs leading-relaxed text-white/45 [text-wrap:balance] sm:text-sm">
            {layers[2].items}
          </p>
        </div>
      </div>

      <!-- Right rail (desktop) -->
      <div class="hidden items-center justify-center lg:flex">
        <span class="whitespace-nowrap text-[11px] font-semibold uppercase tracking-[0.3em] text-white/35 [writing-mode:vertical-rl]">
          {railRight}
        </span>
      </div>
    </div>

    <!-- Bottom rail label (mobile only) -->
    <p class="mt-7 text-center text-[11px] font-semibold uppercase tracking-[0.22em] text-white/35 lg:hidden">
      {railRight}
    </p>
  </div>
</div>
