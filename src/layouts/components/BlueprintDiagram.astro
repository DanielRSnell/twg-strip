---
// 2D Sovereign AI Blueprint diagram (asset from the V3 home page draft).
// Dark panel, three column header pills (Current State / Sovereign AI
// Blueprint / Destination), rows of icon cards with flow arrows.
// Mobile stacks each row vertically with down arrows.

interface Row {
  current: string;
  solution: string;
  destination: string;
}
const { rows } = Astro.props as { rows: Row[] };

const icons = {
  current: [
    '<path d="M21 5H3a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2z"/><path d="M7 10h0"/><path d="M12 10h0"/><path d="M17 10h0"/><path d="M7 14h0"/><path d="M12 14h0"/>',
    '<path d="M16 3h5v5"/><path d="M8 3H3v5"/><path d="M12 22v-8.3a4 4 0 0 0-1.172-2.872L3 3"/><path d="m15 9 6-6"/>',
    '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" y1="11" x2="22" y2="11"/><line x1="19.5" y1="8.5" x2="19.5" y2="13.5"/>',
    '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  ],
  solution: [
    '<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/>',
    '<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>',
    '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
    '<path d="M11 17a5 5 0 0 1-5 5H2v-4a5 5 0 0 1 5-5"/><path d="M13 7a5 5 0 0 1 5-5h4v4a5 5 0 0 1-5 5"/><path d="M8 12h8"/>',
  ],
  destination: [
    '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>',
    '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
    '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
    '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  ],
};

const arrowRight = '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>';
---

<div class="relative overflow-hidden rounded-xl border border-white/10 bg-[#0a0f1c] px-4 py-6 sm:px-6 sm:py-8 lg:px-10 lg:py-10">
  <div class="absolute inset-0 bg-gradient-to-br from-[#0a0f1c] via-[#0d1425] to-[#0a0f1c]"></div>
  <div class="absolute inset-0 opacity-[0.05]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
  <div class="pointer-events-none absolute -top-24 right-1/4 h-[280px] w-[280px] rounded-full bg-[#7c3aed]/[0.08] blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-24 -right-16 h-[280px] w-[280px] rounded-full bg-brand/[0.08] blur-3xl"></div>

  <div class="relative z-10">
    <!-- Column header pills (desktop) -->
    <div class="hidden lg:grid grid-cols-[1fr_28px_1fr_28px_1fr] gap-4 mb-4">
      <div class="rounded-lg bg-white/[0.06] border border-white/10 py-2.5 text-center">
        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-white/70">Current State</p>
      </div>
      <span></span>
      <div class="rounded-lg border border-[#8b5cf6]/40 bg-gradient-to-r from-[#5b21b6] to-[#7c3aed] py-2.5 text-center shadow-[0_0_20px_rgba(124,58,237,0.25)]">
        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-white">Sovereign AI Blueprint</p>
      </div>
      <span></span>
      <div class="rounded-lg border border-brand/40 bg-gradient-to-r from-[#0e6e63] to-[#149183] py-2.5 text-center shadow-[0_0_20px_rgba(36,171,157,0.25)]">
        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-white">Destination</p>
      </div>
    </div>

    <!-- Rows -->
    <div class="flex flex-col gap-3">
      {rows.map((row, i) => (
        <div class="grid lg:grid-cols-[1fr_28px_1fr_28px_1fr] items-stretch gap-2 lg:gap-4">
          <!-- Current -->
          <div class="flex items-center gap-3 rounded-lg border border-white/10 bg-white/[0.04] px-3.5 py-3">
            <span class="shrink-0 flex h-9 w-9 items-center justify-center rounded-md bg-white/[0.08] text-white/70">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons.current[i]} />
            </span>
            <div class="min-w-0">
              <p class="lg:hidden text-[9px] font-bold uppercase tracking-widest text-white/35">Current State</p>
              <p class="text-sm font-medium text-white/85">{row.current}</p>
            </div>
          </div>
          <!-- Arrow -->
          <span class="flex items-center justify-center text-[#a78bfa]">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rotate-90 lg:rotate-0" set:html={arrowRight} />
          </span>
          <!-- Blueprint -->
          <div class="flex items-center gap-3 rounded-lg border border-[#8b5cf6]/30 bg-[#7c3aed]/[0.12] px-3.5 py-3 shadow-[0_0_16px_rgba(124,58,237,0.12)]">
            <span class="shrink-0 flex h-9 w-9 items-center justify-center rounded-md bg-[#7c3aed]/30 text-[#c4b5fd]">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons.solution[i]} />
            </span>
            <div class="min-w-0">
              <p class="lg:hidden text-[9px] font-bold uppercase tracking-widest text-[#a78bfa]/70">Sovereign AI Blueprint</p>
              <p class="text-sm font-medium text-white">{row.solution}</p>
            </div>
          </div>
          <!-- Arrow -->
          <span class="flex items-center justify-center text-brand">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rotate-90 lg:rotate-0" set:html={arrowRight} />
          </span>
          <!-- Destination -->
          <div class="flex items-center gap-3 rounded-lg border border-brand/30 bg-brand/[0.10] px-3.5 py-3 shadow-[0_0_16px_rgba(36,171,157,0.12)]">
            <span class="shrink-0 flex h-9 w-9 items-center justify-center rounded-md bg-brand/20 text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons.destination[i]} />
            </span>
            <div class="min-w-0">
              <p class="lg:hidden text-[9px] font-bold uppercase tracking-widest text-brand/60">Destination</p>
              <p class="text-sm font-medium text-[#5eead4]">{row.destination}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
