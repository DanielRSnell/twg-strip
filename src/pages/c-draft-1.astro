---
import Base from "@/layouts/Base.astro";

const title = "Amalgamy Workflow ROI";
const meta_title = "Amalgamy Workflow ROI - GPU Utilization Analysis";
const description = "Modeled impact of Amalgamy Workflow scheduling on effective GPU utilization: from reserved and idle capacity to effective compute.";

// Cell status palette, validated for CVD separation and contrast on the dark panel.
const cellColors: Record<string, string> = {
  blocked: "#e05d6f",
  idle: "#c08420",
  active: "#24ab9d",
};

const legend = [
  { type: "blocked", label: "Reserved & blocked (data loading)" },
  { type: "idle", label: "Allocated, not in use" },
  { type: "active", label: "Active: effective compute" },
];

const COLS = 16;
const nodeLabel = (n: number) => `N${String(n).padStart(2, "0")}`;

// Before: N01-N08 blocked, N18/N20 active, the rest idle (128 blocked, 160 idle, 32 active)
const beforeRows = Array.from({ length: 20 }, (_, i) => {
  const n = i + 1;
  const type = n <= 8 ? "blocked" : n === 18 || n === 20 ? "active" : "idle";
  return { label: nodeLabel(n), cells: Array(COLS).fill(type) as string[] };
});

// After: all active except one free-headroom cell on N12 and N17 (318 active, 2 headroom)
const afterRows = Array.from({ length: 20 }, (_, i) => {
  const n = i + 1;
  const cells = Array(COLS).fill("active") as string[];
  if (n === 12 || n === 17) cells[COLS - 1] = "idle";
  return { label: nodeLabel(n), cells };
});

const rowTitle = (label: string, cells: string[]) => {
  const counts: Record<string, number> = {};
  cells.forEach((c) => (counts[c] = (counts[c] || 0) + 1));
  const names: Record<string, string> = {
    blocked: "reserved & blocked",
    idle: "allocated, not in use",
    active: "active",
  };
  return `${label}: ` + Object.entries(counts).map(([t, c]) => `${c} ${names[t]}`).join(", ");
};

// Uniform stat tiles: label + hero value + baseline note.
const stats = [
  { label: "Effective GPU utilization", value: "99%", note: "up from 10%" },
  { label: "Throughput lift (modeled)", value: "4.38×", note: "vs. baseline policy" },
  { label: "Completed jobs / 30 days", value: "~36,000", note: "up from ~6,700" },
  { label: "GPUs freed from blocking", value: "+286", note: "vs. baseline policy" },
];

const footnote = "Based on 1,000 Monte Carlo simulations · 10,000-node cluster · 100,000 jobs · 30-day horizon · Amalgamy Workflow ROI analysis";

// Variation 03/04 data: share of the 320-GPU cluster by state.
const composition = {
  before: [
    { type: "blocked", pct: 40, label: "40% blocked" },
    { type: "idle", pct: 50, label: "50% idle" },
    { type: "active", pct: 10, label: "10% active" },
  ],
  after: [
    { type: "active", pct: 99.4, label: "99% active" },
    { type: "idle", pct: 0.6, label: "" },
  ],
};
const donut = (segments: { type: string; pct: number }[]) => {
  let acc = 0;
  const stops = segments.map((s) => {
    const from = acc;
    acc += s.pct;
    return `${cellColors[s.type]} ${from}% ${acc}%`;
  });
  return `conic-gradient(${stops.join(", ")})`;
};
---

<Base title={title} meta_title={meta_title} description={description} noindex={true}>

  <section class="section pt-[130px] lg:pt-[150px]">
    <div class="container">

      <!-- Header -->
      <div class="max-w-3xl mb-12 lg:mb-14">
        <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-brand" data-aos="fade-up-sm" data-aos-delay="50">ROI Analysis</p>
        <h1 class="pb-3 text-3xl lg:text-4xl font-bold" data-aos="fade-up-sm" data-aos-delay="100">Amalgamy Workflow <span class="text-dark/40">ROI</span></h1>
        <p class="text-light leading-relaxed text-lg" data-aos="fade-up-sm" data-aos-delay="150">
          The same cluster, two reservation policies. Late-binding, data-aware scheduling turns reserved and idle capacity into effective compute.
        </p>
      </div>

      <!-- Dark comparison panel: gradient + grid texture + blurred glows behind the waffle grids -->
      <div class="relative overflow-hidden rounded-xl border border-white/10 bg-primary px-5 py-8 sm:px-8 sm:py-10 lg:px-12" data-aos="fade-up-sm" data-aos-delay="100">
        <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
        <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
        <div class="pointer-events-none absolute -top-32 -right-24 h-[400px] w-[400px] rounded-full bg-brand/[0.07] blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-32 -left-24 h-[350px] w-[350px] rounded-full bg-[#5969FC]/[0.05] blur-3xl"></div>

        <div class="relative z-10">
          <!-- Legend -->
          <div class="flex flex-wrap gap-2.5 mb-8">
            {legend.map((item) => (
              <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-1.5 text-xs font-medium text-white/70">
                <span class="h-2.5 w-2.5 rounded-[2px]" style={`background-color: ${cellColors[item.type]}`}></span>
                {item.label}
              </span>
            ))}
          </div>

          <!-- Before / After grids -->
          <div class="grid gap-10 lg:grid-cols-2 lg:gap-12">
            <!-- Before -->
            <div>
              <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-white/35 mb-2">Before</p>
              <h2 class="text-lg font-semibold text-white mb-1">Baseline reservation policy</h2>
              <p class="text-sm text-white/50 mb-6">Nodes locked at job selection, idle during data load</p>
              <div class="waffle-rows">
                {beforeRows.map((row) => (
                  <div class="flex items-center gap-2.5" title={rowTitle(row.label, row.cells)}>
                    <span class="w-7 shrink-0 text-right text-[10px] font-medium text-white/35 tabular-nums">{row.label}</span>
                    <div class="waffle-grid flex-1" style={`grid-template-columns: repeat(${COLS}, minmax(0, 1fr));`}>
                      {row.cells.map((cell) => (
                        <span class="waffle-cell" style={`background-color: ${cellColors[cell]}`}></span>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
              <p class="mt-5 text-sm text-white/45">128 GPUs blocked by data loading &middot; 160 idle &middot; 32 active</p>
            </div>

            <!-- After -->
            <div>
              <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-brand mb-2">After</p>
              <h2 class="text-lg font-semibold text-white mb-1">Amalgamy Workflow scheduling</h2>
              <p class="text-sm text-white/50 mb-6">Late-binding and data-aware: nodes free until job is ready</p>
              <div class="waffle-rows">
                {afterRows.map((row) => (
                  <div class="flex items-center gap-2.5" title={rowTitle(row.label, row.cells)}>
                    <span class="w-7 shrink-0 text-right text-[10px] font-medium text-white/35 tabular-nums">{row.label}</span>
                    <div class="waffle-grid flex-1" style={`grid-template-columns: repeat(${COLS}, minmax(0, 1fr));`}>
                      {row.cells.map((cell) => (
                        <span class="waffle-cell" style={`background-color: ${cellColors[cell]}`}></span>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
              <p class="mt-5 text-sm text-white/45">0 GPUs blocked &middot; 2 free headroom &middot; 318 active</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Stat tiles (uniform: label, before -> after) -->
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4 mt-10">
        {stats.map((stat, i) => (
          <div class="relative overflow-hidden p-7 rounded-2xl border border-border/60 bg-white shadow-sm" data-aos="fade-up-sm" data-aos-delay={(i + 1) * 70}>
            <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-brand/60 via-brand to-brand/60" />
            <p class="text-xs font-semibold uppercase tracking-widest text-dark/40 mb-4 min-h-[2rem]">{stat.label}</p>
            <p class="text-4xl font-bold text-brand tabular-nums tracking-tight">{stat.value}</p>
            <p class="mt-2.5 flex items-center gap-1.5 text-sm text-light">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-brand"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              {stat.note}
            </p>
          </div>
        ))}
      </div>

      <!-- Divider: Variation 02 -->
      <div class="relative my-16 lg:my-20">
        <hr class="border-border/60" />
        <span class="absolute left-1/2 -translate-x-1/2 -top-2.5 bg-body px-4 text-xs font-semibold uppercase tracking-widest text-dark/40 whitespace-nowrap">Variation 02 &middot; Isometric 3D</span>
      </div>

      <!-- Variation 02: isometric planes, active cells raised and lit -->
      <div class="relative overflow-hidden rounded-xl border border-white/10 bg-primary px-5 py-8 sm:px-8 sm:py-10 lg:px-12" data-aos="fade-up-sm">
        <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
        <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
        <div class="pointer-events-none absolute -top-32 -right-24 h-[400px] w-[400px] rounded-full bg-brand/[0.07] blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-32 -left-24 h-[350px] w-[350px] rounded-full bg-[#5969FC]/[0.05] blur-3xl"></div>

        <div class="relative z-10">
          <div class="grid gap-2 lg:grid-cols-2 lg:gap-8">
            <!-- Before plane -->
            <div>
              <div class="text-center">
                <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-white/35 mb-1.5">Before</p>
                <h2 class="text-lg font-semibold text-white mb-1">Baseline reservation policy</h2>
                <p class="text-sm text-white/50">Nodes locked at job selection, idle during data load</p>
              </div>
              <div class="iso-stage">
                <div class="iso-plane">
                  {beforeRows.map((row) => (
                    <div class="iso-row">
                      {row.cells.map((cell) => (
                        <span class={`iso-cell ${cell === "active" ? "iso-raised" : ""}`} style={`background-color: ${cellColors[cell]}`}></span>
                      ))}
                    </div>
                  ))}
                </div>
              </div>
              <p class="text-center text-sm text-white/45">128 GPUs blocked by data loading &middot; 160 idle &middot; 32 active</p>
            </div>
            <!-- After plane -->
            <div>
              <div class="text-center">
                <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-brand mb-1.5">After</p>
                <h2 class="text-lg font-semibold text-white mb-1">Amalgamy Workflow scheduling</h2>
                <p class="text-sm text-white/50">Late-binding and data-aware: nodes free until job is ready</p>
              </div>
              <div class="iso-stage">
                <div class="iso-plane">
                  {afterRows.map((row) => (
                    <div class="iso-row">
                      {row.cells.map((cell) => (
                        <span class={`iso-cell ${cell === "active" ? "iso-raised" : ""}`} style={`background-color: ${cellColors[cell]}`}></span>
                      ))}
                    </div>
                  ))}
                </div>
              </div>
              <p class="text-center text-sm text-white/45">0 GPUs blocked &middot; 2 free headroom &middot; 318 active</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Divider: Variation 03 -->
      <div class="relative my-16 lg:my-20">
        <hr class="border-border/60" />
        <span class="absolute left-1/2 -translate-x-1/2 -top-2.5 bg-body px-4 text-xs font-semibold uppercase tracking-widest text-dark/40 whitespace-nowrap">Variation 03 &middot; Utilization gauges</span>
      </div>

      <!-- Variation 03: composition donuts with hero centers -->
      <div class="relative overflow-hidden rounded-xl border border-white/10 bg-primary px-5 py-10 sm:px-8 lg:px-12 lg:py-14" data-aos="fade-up-sm">
        <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
        <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
        <div class="pointer-events-none absolute -top-32 -right-24 h-[400px] w-[400px] rounded-full bg-brand/[0.07] blur-3xl"></div>

        <div class="relative z-10">
          <div class="flex flex-wrap gap-2.5 mb-10 justify-center">
            {legend.map((item) => (
              <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-1.5 text-xs font-medium text-white/70">
                <span class="h-2.5 w-2.5 rounded-[2px]" style={`background-color: ${cellColors[item.type]}`}></span>
                {item.label}
              </span>
            ))}
          </div>
          <div class="grid gap-12 sm:grid-cols-2 max-w-2xl mx-auto">
            <div class="text-center">
              <div class="relative mx-auto w-48 h-48 lg:w-56 lg:h-56 rounded-full" style={`background: ${donut(composition.before)}`}>
                <div class="absolute inset-[16%] rounded-full bg-[#0d1117] border border-white/[0.06] flex flex-col items-center justify-center">
                  <span class="text-4xl font-bold text-white tabular-nums">10%</span>
                  <span class="text-xs uppercase tracking-widest text-white/40 mt-1">effective</span>
                </div>
              </div>
              <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-white/35 mt-6 mb-1">Before</p>
              <p class="text-base font-semibold text-white">Baseline reservation policy</p>
            </div>
            <div class="text-center">
              <div class="relative mx-auto w-48 h-48 lg:w-56 lg:h-56 rounded-full shadow-[0_0_50px_rgba(36,171,157,0.15)]" style={`background: ${donut(composition.after)}`}>
                <div class="absolute inset-[16%] rounded-full bg-[#0d1117] border border-white/[0.06] flex flex-col items-center justify-center">
                  <span class="text-4xl font-bold text-brand tabular-nums">99%</span>
                  <span class="text-xs uppercase tracking-widest text-white/40 mt-1">effective</span>
                </div>
              </div>
              <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-brand mt-6 mb-1">After</p>
              <p class="text-base font-semibold text-white">Amalgamy Workflow scheduling</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Divider: Variation 04 -->
      <div class="relative my-16 lg:my-20">
        <hr class="border-border/60" />
        <span class="absolute left-1/2 -translate-x-1/2 -top-2.5 bg-body px-4 text-xs font-semibold uppercase tracking-widest text-dark/40 whitespace-nowrap">Variation 04 &middot; Composition bars</span>
      </div>

      <!-- Variation 04: 100% stacked composition bars -->
      <div class="relative overflow-hidden rounded-xl border border-white/10 bg-primary px-5 py-10 sm:px-8 lg:px-12 lg:py-14" data-aos="fade-up-sm">
        <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
        <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
        <div class="pointer-events-none absolute -bottom-32 -left-24 h-[350px] w-[350px] rounded-full bg-brand/[0.06] blur-3xl"></div>

        <div class="relative z-10 max-w-3xl mx-auto">
          <div class="flex flex-wrap gap-2.5 mb-10">
            {legend.map((item) => (
              <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-1.5 text-xs font-medium text-white/70">
                <span class="h-2.5 w-2.5 rounded-[2px]" style={`background-color: ${cellColors[item.type]}`}></span>
                {item.label}
              </span>
            ))}
          </div>

          <div class="mb-10">
            <div class="flex items-baseline justify-between mb-3">
              <p class="text-base font-semibold text-white">Baseline reservation policy</p>
              <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-white/35">Before</p>
            </div>
            <div class="flex h-12 rounded-lg overflow-hidden gap-[2px]">
              {composition.before.map((seg) => (
                <div class="flex items-center justify-center" style={`width: ${seg.pct}%; background-color: ${cellColors[seg.type]}`}>
                  {seg.label && <span class="text-xs font-semibold text-[#0d1117]/80 whitespace-nowrap px-2">{seg.label}</span>}
                </div>
              ))}
            </div>
            <p class="mt-3 text-sm text-white/45">128 GPUs blocked by data loading &middot; 160 idle &middot; 32 active</p>
          </div>

          <div>
            <div class="flex items-baseline justify-between mb-3">
              <p class="text-base font-semibold text-white">Amalgamy Workflow scheduling</p>
              <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-brand">After</p>
            </div>
            <div class="flex h-12 rounded-lg overflow-hidden gap-[2px]">
              {composition.after.map((seg) => (
                <div class="flex items-center justify-center" style={`width: ${seg.pct}%; background-color: ${cellColors[seg.type]}`}>
                  {seg.label && <span class="text-xs font-semibold text-[#0d1117]/80 whitespace-nowrap px-2">{seg.label}</span>}
                </div>
              ))}
            </div>
            <p class="mt-3 text-sm text-white/45">0 GPUs blocked &middot; 2 free headroom &middot; 318 active</p>
          </div>
        </div>
      </div>

      <!-- Footnote -->
      <p class="mt-8 text-sm text-light" data-aos="fade-up-sm">{footnote}</p>

    </div>
  </section>
</Base>

<style>
  .waffle-rows > * + * {
    margin-top: 3px;
  }
  .waffle-grid {
    display: grid;
    gap: 2px;
  }
  .waffle-cell {
    aspect-ratio: 1 / 1;
    border-radius: 2px;
  }

  /* Variation 02: isometric planes */
  .iso-stage {
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1600px;
    --iso-scale: 0.72;
  }
  @media (min-width: 540px) {
    .iso-stage {
      height: 360px;
      --iso-scale: 0.95;
    }
  }
  @media (min-width: 1024px) {
    .iso-stage {
      height: 380px;
      --iso-scale: 0.9;
    }
  }
  @media (min-width: 1280px) {
    .iso-stage {
      --iso-scale: 1.05;
    }
  }
  .iso-plane {
    width: 340px;
    transform: scale(var(--iso-scale)) rotateX(55deg) rotateZ(-42deg);
    transform-style: preserve-3d;
    filter: drop-shadow(-20px 30px 30px rgba(0, 0, 0, 0.55));
  }
  .iso-row {
    display: grid;
    grid-template-columns: repeat(16, minmax(0, 1fr));
    gap: 3px;
    transform-style: preserve-3d;
  }
  .iso-row + .iso-row {
    margin-top: 3px;
  }
  .iso-cell {
    aspect-ratio: 1 / 1;
    border-radius: 2px;
    opacity: 0.85;
  }
  .iso-raised {
    opacity: 1;
    transform: translateZ(14px);
    box-shadow:
      0 0 10px rgba(36, 171, 157, 0.55),
      0 0 22px rgba(36, 171, 157, 0.25);
  }
</style>
