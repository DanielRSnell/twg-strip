---
import config from "@/config/config.json";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import "@/styles/main.scss";
import { AstroFont } from "astro-font";
import "aos/dist/aos.css";
import InterviewFunnel from "@/components/InterviewFunnel";

import texasTechConfig from "@/config/interviews/texas-tech.json";
import wattsToWorkersConfig from "@/config/interviews/watts-to-workers.json";

export function getStaticPaths() {
  const configs = [texasTechConfig, wattsToWorkersConfig];
  return configs.map((c) => ({
    params: { client: c.client },
    props: { clientConfig: c },
  }));
}

const { clientConfig } = Astro.props;

const pf = theme.fonts.font_family.primary;
const sf = theme.fonts.font_family.secondary;

let fontPrimary, fontSecondary;
if (theme.fonts.font_family.primary) {
  fontPrimary = theme.fonts.font_family.primary
    .replace(/\+/g, " ")
    .replace(/:[ital,]*[ital@]*[wght@]*[0-9,;.]+/gi, "");
}
if (theme.fonts.font_family.secondary) {
  fontSecondary = theme.fonts.font_family.secondary
    .replace(/\+/g, " ")
    .replace(/:[ital,]*[ital@]*[wght@]*[0-9,;.]+/gi, "");
}

const title = `${clientConfig.title} | ${clientConfig.name}`;
const meta_title = `${clientConfig.title} | ${clientConfig.name} | ThisWay Global`;
const description = `Complete your interview process for ${clientConfig.name} through ThisWay Global.`;
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="shortcut icon" href={config.site.favicon} />
    <meta name="theme-color" content="#fff" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <AstroFont
      config={[
        {
          src: [],
          preload: false,
          display: "swap",
          name: fontPrimary!,
          fallback: "sans-serif",
          cssVariable: "font-primary",
          googleFontsURL: `https://fonts.googleapis.com/css2?family=${pf}&display=swap`,
        },
        {
          src: [],
          preload: false,
          display: "swap",
          name: fontSecondary!,
          fallback: "sans-serif",
          cssVariable: "font-secondary",
          googleFontsURL: `https://fonts.googleapis.com/css2?family=${sf}&display=swap`,
        },
      ]}
    />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />
    <title>{plainify(meta_title)}</title>
    <meta name="description" content={plainify(description)} />
    <meta property="og:title" content={plainify(meta_title)} />
    <meta property="og:description" content={plainify(description)} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${config.site.base_url}/images/og-image.png`} />
  </head>
  <body class="min-h-screen bg-theme-light">
    <header class="py-8 text-center">
      <div class="flex items-center justify-center gap-4">
        <a href="/" class="inline-block">
          <img
            src="/images/logo.svg"
            alt="ThisWay Global"
            class="h-10"
          />
        </a>
        <div class="h-8 w-px bg-gray-300"></div>
        <img
          src={clientConfig.logo}
          alt={clientConfig.name}
          class="h-12 w-auto"
        />
      </div>
    </header>

    <main class="px-4 pb-16">
      <div class="mx-auto max-w-3xl">
        <div
          class="mb-10 text-center"
          data-aos="fade-up-sm"
          data-aos-delay="100"
        >
          <h1 class="mb-4 text-3xl font-semibold text-dark sm:text-4xl">
            {clientConfig.title}
          </h1>
          <p class="mx-auto max-w-xl text-base text-light">
            {clientConfig.subtitle}
          </p>
        </div>

        <div data-aos="fade-up-sm" data-aos-delay="400">
          <InterviewFunnel client:load config={clientConfig} />
        </div>
      </div>
    </main>

    <script>
      import AOS from "aos";
      function aosInit() {
        AOS.init({ duration: 600, once: true });
      }
      aosInit();
      document.addEventListener("astro:after-swap", aosInit);
    </script>
  </body>
</html>
