---
import Base from "@/layouts/Base.astro";

const title = "Amalgamy Architecture Diagrams";
const meta_title = "Amalgamy Architecture - Workflow & Value Flow Diagrams";
const description = "Technical architecture diagrams showing Amalgamy's unified AI/HPC orchestration workflow and value flow across infrastructure layers.";
---

<Base title={title} meta_title={meta_title} description={description}>

  <!-- Page Header -->
  <section class="relative overflow-hidden bg-primary pt-[100px] pb-[40px] lg:pt-[120px] lg:pb-[50px]">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
    <div class="absolute -top-20 -right-20 w-[350px] h-[350px] rounded-full bg-brand/10 blur-3xl pointer-events-none"></div>
    <div class="container relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 mb-6 text-sm font-medium text-white/90 rounded-full border border-white/[0.08] bg-white/[0.04] backdrop-blur-sm">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-brand shadow-[0_0_6px_rgba(36,171,157,0.6)]"></span>
          Technical Architecture
        </div>
        <h1 class="mb-4 text-3xl lg:text-4xl font-extrabold text-white">
          Amalgamy Architecture <span class="text-white/50">Diagrams</span>
        </h1>
        <p class="text-lg text-white/50 leading-relaxed">
          Visual reference for Amalgamy's orchestration workflow and value flow across sovereign AI/HPC infrastructure.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================
       DIAGRAM 1: Amalgamy Workflow Architecture
       ============================================ -->
  <section class="relative bg-primary py-12 lg:py-16">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
    <div class="container relative z-10">
      <div class="overflow-x-auto pb-4">
        <div class="arch-wrapper">

          <!-- Title -->
          <div class="arch-title-bar">
            Amalgamy Workflow Architecture
          </div>

          <!-- Main 3-column layout -->
          <div class="arch-main">

            <!-- LEFT COLUMN: Researcher Terminal -->
            <div class="arch-left">
              <div class="arch-box arch-box-gray arch-left-box">
                <div class="arch-box-title">Researcher Terminal / Nextflow</div>
                <div class="arch-box-sub">Standard workloads. Zero friction.</div>
              </div>
            </div>

            <!-- CENTER COLUMN: Stacked layers -->
            <div class="arch-center">

              <!-- Layer 1: Management & Intent -->
              <div class="arch-layer">
                <div class="arch-layer-label">AMALGAMY MANAGEMENT & INTENT</div>
                <div class="arch-box arch-box-cyan">
                  <div class="arch-box-title">Zero-Trust Policy Manager (ReBAC / ABAC)</div>
                  <div class="arch-box-sub">CISO dynamic isolation rules & data classifications</div>
                </div>
              </div>

              <!-- Vertical connector -->
              <div class="arch-vline"></div>

              <!-- Layer 2: Meta-Orchestrator & Control -->
              <div class="arch-layer">
                <div class="arch-layer-label">AMALGAMY META-ORCHESTRATOR & CONTROL</div>
                <div class="arch-orch-grid">
                  <!-- AW-Interceptors -->
                  <div class="arch-sublayer">
                    <div class="arch-sublayer-label">AW-Interceptors</div>
                    <div class="arch-box arch-box-gray arch-box-inner">
                      <div class="arch-box-title">Slurm Workload Manager</div>
                    </div>
                  </div>

                  <!-- Connection annotation -->
                  <div class="arch-connection">
                    <div class="arch-annotation arch-annotation-yellow">JSON over Unix Socket<br/>(Fails Open)</div>
                    <svg width="40" height="16" viewBox="0 0 40 16" fill="none" class="arch-arrow-h"><path d="M0 8h36m0 0l-5-5m5 5l-5 5" stroke="#24ab9d" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/></svg>
                  </div>

                  <!-- AW-Daemon -->
                  <div class="arch-sublayer arch-sublayer-wide">
                    <div class="arch-sublayer-label">AW-Daemon</div>
                    <div class="arch-daemon-row">
                      <div class="arch-box arch-box-cyan arch-box-sm">
                        <div class="arch-box-title">AW-Policy</div>
                      </div>
                      <div class="arch-box arch-box-cyan arch-box-sm">
                        <div class="arch-box-title">AW-Spy</div>
                        <div class="arch-box-sub">(Data Orchestrator)</div>
                      </div>
                      <div class="arch-box arch-box-cyan arch-box-sm">
                        <div class="arch-box-title">AW-Netiso</div>
                        <div class="arch-box-sub">(Network Orchestrator)</div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="arch-annotation arch-annotation-yellow arch-annotation-center">Pre-Flight Gate: Intent validated before hold</div>
              </div>

              <!-- Vertical connector -->
              <div class="arch-vline"></div>

              <!-- Layer 3: Node & Network Enforcement -->
              <div class="arch-layer">
                <div class="arch-layer-label">AMALGAMY NODE & NETWORK ENFORCEMENT</div>
                <div class="arch-enforce-grid">
                  <div class="arch-box arch-box-cyan">
                    <div class="arch-box-title">Kernel LSM (File I/O Enforcement)</div>
                    <div class="arch-box-sub">Binary pass/fail enforcement at syscall level</div>
                  </div>
                  <div class="arch-box arch-box-cyan">
                    <div class="arch-box-title">AW-Switch Controller</div>
                    <div class="arch-box-sub">Network fabric control</div>
                  </div>
                </div>
              </div>

              <!-- Vertical connector -->
              <div class="arch-vline arch-vline-dim"></div>

              <!-- Layer 4: Sovereign Infrastructure -->
              <div class="arch-layer arch-layer-infra">
                <div class="arch-layer-label arch-layer-label-gray">SOVEREIGN INFRASTRUCTURE (BARE METAL, VMS, CLOUD)</div>
                <div class="arch-infra-grid">
                  <div class="arch-box arch-box-gray">
                    <div class="arch-box-title">Compute Nodes & Switches</div>
                    <div class="arch-box-sub">Target Accelerators | Physical Network Switches | Node-Local NVMe</div>
                  </div>
                  <div class="arch-data-staging">
                    <div class="arch-data-staging-line"></div>
                    <div class="arch-data-staging-label">Data Staging</div>
                    <div class="arch-data-staging-arrows">
                      <svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M0 5h8m0 0l-3-3m3 3l-3 3" stroke="#f59e0b" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/></svg>
                      <svg width="12" height="10" viewBox="0 0 12 10" fill="none" class="arch-flip-h"><path d="M0 5h8m0 0l-3-3m3 3l-3 3" stroke="#f59e0b" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/></svg>
                    </div>
                  </div>
                  <div class="arch-box arch-box-gray">
                    <div class="arch-box-title">Enterprise Storage Fabric</div>
                    <div class="arch-box-sub">S3 | Lustre</div>
                  </div>
                </div>
                <div class="arch-annotation arch-annotation-yellow arch-annotation-center">Asynchronous data staging (Accelerator meter paused)</div>
              </div>

            </div>

            <!-- RIGHT COLUMN: Unified Telemetry & Audit -->
            <div class="arch-right">
              <div class="arch-right-container">
                <div class="arch-right-label">UNIFIED TELEMETRY & AUDIT</div>
                <div class="arch-right-stack">
                  <div class="arch-box arch-box-cyan">
                    <div class="arch-box-title">UI Dashboards</div>
                    <div class="arch-box-sub">Yield Ledger</div>
                    <div class="arch-box-sub">Compliance Dashboard</div>
                  </div>
                  <div class="arch-h-note">
                    <span class="arch-h-note-arrow">←</span> Queue & utilization metrics
                  </div>
                  <div class="arch-box arch-box-cyan">
                    <div class="arch-box-title">Immutable Audit Ledger</div>
                    <div class="arch-box-sub">Secure event log</div>
                  </div>
                  <div class="arch-h-note">
                    <span class="arch-h-note-arrow">←</span> ReBAC/ABAC I/O events
                  </div>
                  <div class="arch-box arch-box-cyan">
                    <div class="arch-box-title">AW-Telemetry & Event Bus</div>
                    <div class="arch-box-sub">Prometheus metrics & tracing</div>
                  </div>
                </div>
              </div>
            </div>

          </div>

          <!-- Legend -->
          <div class="arch-legend">
            <div class="arch-legend-item">
              <span class="arch-legend-swatch arch-legend-cyan"></span>
              <span>Amalgamy Component</span>
            </div>
            <div class="arch-legend-item">
              <span class="arch-legend-swatch arch-legend-gray"></span>
              <span>Legacy Infrastructure</span>
            </div>
            <div class="arch-legend-item">
              <span class="arch-legend-arrow arch-legend-arrow-yellow">→</span>
              <span>Data Staging</span>
            </div>
            <div class="arch-legend-item">
              <span class="arch-legend-line arch-legend-line-cyan"></span>
              <span>Telemetry / Data Flow</span>
            </div>
            <div class="arch-legend-item">
              <span class="arch-legend-arrow arch-legend-arrow-gray">→</span>
              <span>Control Signal (top-down)</span>
            </div>
            <div class="arch-legend-item">
              <span class="arch-legend-arrow arch-legend-arrow-yellow">→</span>
              <span>Telemetry Exhaust</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="bg-primary">
    <div class="container">
      <div class="h-px bg-gradient-to-r from-transparent via-brand/30 to-transparent"></div>
    </div>
  </div>

  <!-- ============================================
       DIAGRAM 2: Value Flow Diagram
       ============================================ -->
  <section class="relative bg-primary py-12 lg:py-16">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
    <div class="container relative z-10">
      <div class="mb-8 text-center">
        <h2 class="text-2xl lg:text-3xl font-bold text-white mb-2">
          Amalgamy.ai Workflow: Value Flow Diagram
        </h2>
        <p class="text-sm text-white/40">
          End-to-end workflow from job submission through policy enforcement, data staging, execution, and teardown
        </p>
      </div>

      <div class="overflow-x-auto pb-4">
        <div class="vf-wrapper">

          <!-- Step Headers -->
          <div class="vf-header-row">
            <div class="vf-row-label"></div>
            <div class="vf-col-header">
              <span class="vf-step-num">Step 1</span>
              <span class="vf-step-name">Intent & Ingestion</span>
            </div>
            <div class="vf-col-header">
              <span class="vf-step-num">Step 2</span>
              <span class="vf-step-name">Intercept & Policy Gate</span>
            </div>
            <div class="vf-col-header">
              <span class="vf-step-num">Step 3</span>
              <span class="vf-step-name">Data Staging</span>
            </div>
            <div class="vf-col-header">
              <span class="vf-step-num">Step 4</span>
              <span class="vf-step-name">Network Isolation & Execution</span>
            </div>
            <div class="vf-col-header">
              <span class="vf-step-num">Step 5</span>
              <span class="vf-step-name">Teardown & Audit</span>
            </div>
          </div>

          <!-- Row 1: User Plane -->
          <div class="vf-data-row">
            <div class="vf-row-label">
              <span class="vf-row-label-icon">👤</span>
              <span class="vf-row-label-text">User Plane<br/><span class="vf-row-label-sub">(Researcher / CISO)</span></span>
            </div>
            <div class="vf-cell">
              <div class="vf-box vf-box-white">
                <div class="vf-box-title">Researcher submits unmodified sbatch or Nextflow script</div>
              </div>
            </div>
            <div class="vf-cell"></div>
            <div class="vf-cell"></div>
            <div class="vf-cell"></div>
            <div class="vf-cell">
              <div class="vf-box vf-box-white">
                <div class="vf-box-title">Immutable compliance report → CISO</div>
                <div class="vf-box-desc">Yield report → Admin</div>
              </div>
            </div>
          </div>

          <!-- Flow Arrows -->
          <div class="vf-flow-indicator">
            <div class="vf-row-label"></div>
            <div class="vf-flow-arrow-cell"><svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 0v16m0 0l-4-4m4 4l4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.2"/></svg></div>
            <div class="vf-flow-arrow-cell"></div>
            <div class="vf-flow-arrow-cell"></div>
            <div class="vf-flow-arrow-cell"></div>
            <div class="vf-flow-arrow-cell"></div>
          </div>

          <!-- Row 2: Amalgamy Workflow Orchestrator -->
          <div class="vf-data-row">
            <div class="vf-row-label">
              <span class="vf-row-label-text">Amalgamy<br/>Workflow<br/>Orchestrator<br/>Plane</span>
            </div>
            <div class="vf-cell"></div>
            <div class="vf-cell">
              <div class="vf-box vf-box-cyan">
                <div class="vf-box-title">Amalgamy Workflow intercepts job.</div>
                <div class="vf-box-desc">Paces on "System Hold"</div>
              </div>
            </div>
            <div class="vf-cell"></div>
            <div class="vf-cell">
              <div class="vf-box vf-box-cyan">
                <div class="vf-box-title">Data ready. AW-Netiso reads ReBAC policy & isolates switches</div>
              </div>
            </div>
            <div class="vf-cell">
              <div class="vf-box vf-box-cyan">
                <div class="vf-box-title">Amalgamy Workflow cleans up</div>
              </div>
            </div>
          </div>

          <!-- Flow Arrows -->
          <div class="vf-flow-indicator">
            <div class="vf-row-label"></div>
            <div class="vf-flow-arrow-cell"></div>
            <div class="vf-flow-arrow-cell"><svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 0v16m0 0l-4-4m4 4l4-4" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/></svg></div>
            <div class="vf-flow-arrow-cell"><svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 0v16m0 0l-4-4m4 4l4-4" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/></svg></div>
            <div class="vf-flow-arrow-cell"><svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 0v16m0 0l-4-4m4 4l4-4" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/></svg></div>
            <div class="vf-flow-arrow-cell"><svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 0v16m0 0l-4-4m4 4l4-4" stroke="#24ab9d" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/></svg></div>
          </div>

          <!-- Row 3: Node & Network Enforcement -->
          <div class="vf-data-row">
            <div class="vf-row-label">
              <span class="vf-row-label-text">Amalgamy<br/>Data &<br/>Security<br/>Plane</span>
            </div>
            <div class="vf-cell"></div>
            <div class="vf-cell">
              <div class="vf-box vf-box-yellow">
                <div class="vf-box-title">Policy Pre-Flight Check</div>
                <div class="vf-box-desc">Validates user intent vs. data classification.<br/><strong>Fail → Job Killed | Pass → Proceed</strong></div>
              </div>
            </div>
            <div class="vf-cell">
              <div class="vf-box vf-box-yellow">
                <div class="vf-box-title">Amalgamy Workflow stages data to local NVMe</div>
                <div class="vf-box-desc"><strong>(GPU meter is PAUSED)</strong></div>
              </div>
            </div>
            <div class="vf-cell">
              <div class="vf-box vf-box-yellow">
                <div class="vf-box-title">Kernel LSM evaluates every POSIX read/write</div>
                <div class="vf-box-desc">to prevent lateral movement & credential hijacking</div>
              </div>
            </div>
            <div class="vf-cell">
              <div class="vf-box vf-box-cyan">
                <div class="vf-box-title">Local data cache scrubbed</div>
              </div>
            </div>
          </div>

          <!-- Flow Arrows -->
          <div class="vf-flow-indicator">
            <div class="vf-row-label"></div>
            <div class="vf-flow-arrow-cell"><svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 0v16m0 0l-4-4m4 4l4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.15"/></svg></div>
            <div class="vf-flow-arrow-cell"><svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 0v16m0 0l-4-4m4 4l4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.15"/></svg></div>
            <div class="vf-flow-arrow-cell"><svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 0v16m0 0l-4-4m4 4l4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.15"/></svg></div>
            <div class="vf-flow-arrow-cell"><svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 0v16m0 0l-4-4m4 4l4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.15"/></svg></div>
            <div class="vf-flow-arrow-cell"><svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 0v16m0 0l-4-4m4 4l4-4" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/></svg></div>
          </div>

          <!-- Row 4: Sovereign Infrastructure -->
          <div class="vf-data-row">
            <div class="vf-row-label">
              <span class="vf-row-label-text">Sovereign<br/>Infrastructure</span>
            </div>
            <div class="vf-cell">
              <div class="vf-box vf-box-gray">
                <div class="vf-box-title">Enters standard Slurm queue</div>
              </div>
            </div>
            <div class="vf-cell">
              <div class="vf-box vf-box-cyan">
                <div class="vf-box-title">Target Compute (Accelerators, HBM, Network) remains UNALLOCATED</div>
              </div>
            </div>
            <div class="vf-cell">
              <div class="vf-box vf-box-cyan">
                <div class="vf-box-title">Premium Resources (Accelerators, HBM, Network Fabric) remain fully available to other users</div>
              </div>
            </div>
            <div class="vf-cell">
              <div class="vf-box vf-box-cyan vf-box-highlight">
                <div class="vf-box-title">Ephemeral VxLAN/NVLink Domain</div>
                <div class="vf-box-desc">Accelerators and other resources allocated. Meter STARTS. Job runs inside isolated domain.</div>
              </div>
            </div>
            <div class="vf-cell">
              <div class="vf-box vf-box-red">
                <div class="vf-box-title">Network Destroyed</div>
              </div>
            </div>
          </div>

          <!-- Legend -->
          <div class="vf-legend">
            <div class="vf-legend-item">
              <span class="vf-legend-swatch vf-legend-cyan"></span>
              <span>Amalgamy Component</span>
            </div>
            <div class="vf-legend-item">
              <span class="vf-legend-swatch vf-legend-gray"></span>
              <span>Legacy Infrastructure</span>
            </div>
            <div class="vf-legend-item">
              <span class="vf-legend-swatch vf-legend-yellow"></span>
              <span>Security / Policy Gate</span>
            </div>
            <div class="vf-legend-item">
              <span class="vf-legend-swatch vf-legend-red"></span>
              <span>Destructive Action</span>
            </div>
            <div class="vf-legend-item">
              <span class="vf-legend-swatch vf-legend-white"></span>
              <span>User Plane</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Bottom padding -->
  <div class="bg-primary pb-16"></div>

  <style is:global>
    /* ============================================
       DIAGRAM 1: Workflow Architecture
       ============================================ */

    .arch-wrapper {
      min-width: 1050px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .arch-title-bar {
      text-align: center;
      font-size: 20px;
      font-weight: 700;
      color: #fff;
      padding: 12px 40px;
      border: 1px solid rgba(89, 105, 252, 0.4);
      border-radius: 10px;
      background: rgba(89, 105, 252, 0.08);
      margin-bottom: 20px;
    }

    .arch-main {
      display: grid;
      grid-template-columns: 190px 1fr 210px;
      gap: 20px;
      align-items: stretch;
    }

    .arch-left {
      display: flex;
      align-items: flex-start;
      padding-top: 50px;
    }

    .arch-center {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .arch-right {
      display: flex;
      flex-direction: column;
    }

    .arch-right-container {
      border: 1px dashed rgba(36, 171, 157, 0.25);
      border-radius: 12px;
      padding: 12px;
      flex: 1;
      display: flex;
      flex-direction: column;
      position: relative;
    }

    .arch-right-label {
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: rgba(36, 171, 157, 0.6);
      text-align: center;
      padding: 6px 0;
      border-bottom: 1px solid rgba(36, 171, 157, 0.15);
      margin-bottom: 10px;
    }

    .arch-right-stack {
      display: flex;
      flex-direction: column;
      gap: 10px;
      flex: 1;
    }

    /* Horizontal connection notes between right-column boxes */
    .arch-h-note {
      font-size: 9px;
      color: rgba(245, 158, 11, 0.55);
      padding: 2px 0 2px 4px;
      letter-spacing: 0.02em;
      line-height: 1;
    }
    .arch-h-note-arrow {
      color: rgba(36, 171, 157, 0.4);
      font-size: 11px;
      margin-right: 3px;
    }

    /* Left column connection arrow */
    .arch-left {
      position: relative;
    }
    .arch-left-box {
      width: 100%;
    }
    .arch-left::after {
      content: '';
      position: absolute;
      right: -12px;
      top: 85px;
      width: 10px;
      height: 1px;
      background: rgba(255, 255, 255, 0.12);
    }

    /* Layers */
    .arch-layer {
