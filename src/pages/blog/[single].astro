---
import Base from "@/layouts/Base.astro";
import PostSingle from "@/layouts/PostSingle.astro";
import VideoSingle from "@/layouts/VideoSingle.astro";
import AudioSingle from "@/layouts/AudioSingle.astro";
import PressSingle from "@/layouts/PressSingle.astro";
import { getSinglePage } from "@/lib/contentParser.astro";

export async function getStaticPaths() {
  const BLOG_FOLDER = "blog";
  const posts = await getSinglePage(BLOG_FOLDER);

  const paths = posts.map((post) => ({
    params: {
      single: post.slug,
    },
    props: { post },
  }));
  return paths;
}

const { post } = Astro.props;
const { title, meta_title, description, image, type, author, date } = post.data;

import config from "@/config/config.json";
const articleSchema = type === 'post' ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description || "",
  "image": image ? `${config.site.base_url}${image}` : undefined,
  "datePublished": date ? new Date(date).toISOString() : undefined,
  "author": {
    "@type": "Person",
    "name": author || "ThisWay Global"
  },
  "publisher": {
    "@type": "Organization",
    "name": "ThisWay Global",
    "logo": {
      "@type": "ImageObject",
      "url": `${config.site.base_url}/images/logo.svg`
    }
  }
}) : null;

const layouts = {
  post: PostSingle,
  video: VideoSingle,
  audio: AudioSingle,
  press: PressSingle,
};

const ContentLayout = layouts[type];
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  <ContentLayout post={post} />
  {articleSchema && <script type="application/ld+json" set:html={articleSchema} />}
</Base>
