---
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { getEntry } from "astro:content";
import HeroInfographic from "@/helpers/HeroInfographic";

const homepage = await getEntry("homepage", "-index");
const { banner, value_props, social_proof, amalgamy, blueprint, tracks, coop, empower, cta_section } = homepage.data;
---

<Base>
  <!-- Banner -->
  <section class="relative overflow-hidden bg-primary pt-[100px] pb-[80px] lg:pt-[120px] lg:pb-[100px]">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
    <div class="container relative z-10">
      <div class="items-center row gy-5">
        <div class="lg:col-7">
          <h1
            class="mb-6 font-extrabold hero-gradient-text"
            data-aos="fade-right-sm"
            data-aos-delay="100"
            set:html={markdownify(banner.title)}
          />
          <div
            class="mb-10 max-w-xl text-lg leading-relaxed text-white/60 [&>p]:mb-4 [&>p:last-child]:mb-0"
            data-aos="fade-right-sm"
            data-aos-delay="200"
            set:html={markdownify(banner.content)}
          />
          <div
            class="flex flex-wrap gap-4"
            data-aos="fade-right-sm"
            data-aos-delay="300"
          >
            {banner.button?.enable && (
              <a
                class="group relative inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-white rounded-full bg-brand border border-brand/80 shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_20px_rgba(36,171,157,0.15)] hover:shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_30px_rgba(36,171,157,0.25)] hover:bg-brand/90 transition-all duration-300"
                href={banner.button.link}
              >
                {banner.button.label}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            )}
            {banner.button_secondary?.enable && (
              <a
                class="group relative inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-white/90 rounded-full border border-white/[0.12] bg-white/[0.04] backdrop-blur-sm hover:bg-white/[0.08] hover:border-white/[0.2] transition-all duration-300"
                href={banner.button_secondary.link}
              >
                {banner.button_secondary.label}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            )}
          </div>
        </div>
        <div class="hidden lg:block lg:col-5">
          <HeroInfographic client:visible />
        </div>
      </div>
    </div>
  </section>
  <!-- /Banner -->

  <!-- What We Deliver -->
  {value_props && (
    <section class="section">
      <div class="container">
        <div class="grid gap-6 lg:grid-cols-3 mb-8">
          {value_props.columns.map((col, i) => (
            <div
              class="relative p-8 rounded-2xl border border-border/60 bg-white shadow-sm overflow-hidden"
              data-aos="fade-up-sm"
              data-aos-delay={(i + 1) * 100}
            >
              <div class="absolute top-0 inset-x-0 h-[2px] bg-gradient-to-r from-brand/40 via-brand/80 to-brand/40" />
              <h3 class="mb-3 text-lg font-semibold">{col.title}</h3>
              <p class="text-sm text-light leading-relaxed">{col.text}</p>
            </div>
          ))}
        </div>
        <p
          class="text-center text-lg font-semibold text-dark"
          data-aos="fade-up-sm"
          data-aos-delay="400"
          set:html={markdownify(value_props.result)}
        />
      </div>
    </section>
  )}
  <!-- /What We Deliver -->

  <!-- Social Proof / Case Study -->
  {social_proof && (
    <section class="section pt-0">
      <div class="container">
        <div class="justify-center mb-8 row">
          <div class="lg:col-8">
            <h2
              class="pb-2 text-center"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(social_proof.title)}
            />
            <p
              class="text-center text-xl font-semibold text-brand"
              data-aos="fade-up-sm"
              data-aos-delay="200"
            >
              {social_proof.subtitle}
            </p>
          </div>
        </div>

        {social_proof.case_study && (
          <div
            class="relative rounded-2xl bg-primary overflow-hidden p-8 lg:p-12"
            data-aos="fade-up-sm"
            data-aos-delay="300"
          >
            <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
            <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
            <div class="absolute -top-20 -right-20 w-[350px] h-[350px] rounded-full bg-brand/10 blur-3xl pointer-events-none" />
            <div class="relative z-10 row gy-8 items-start">
              <div class="lg:col-7">
                <p class="text-white/60 leading-relaxed">{social_proof.case_study.description}</p>
              </div>
              <div class="lg:col-5">
                <div class="relative p-6 rounded-xl border border-white/[0.08] bg-white/[0.03] backdrop-blur-sm">
                  <div class="absolute left-0 inset-y-0 w-1 bg-gradient-to-b from-brand/60 via-brand to-brand/60 rounded-l-xl" />
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-brand/40 mb-3"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                  <p class="text-sm text-white/70 leading-relaxed italic mb-3">{social_proof.case_study.quote}</p>
                  <p class="text-xs text-brand font-semibold">{social_proof.case_study.attribution}</p>
                </div>
              </div>
            </div>
          </div>
        )}
      </div>
    </section>
  )}
  <!-- /Social Proof -->

  <!-- Amalgamy -->
  {amalgamy && (
    <section class="relative section bg-primary overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
      <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
      <div class="absolute -top-40 -right-40 w-[500px] h-[500px] rounded-full bg-brand/8 blur-3xl pointer-events-none" />
      <div class="container relative z-10">
        <div class="justify-center mb-8 row">
          <div class="lg:col-8">
            <h2
              class="pb-4 text-center text-white"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(amalgamy.title)}
            />
            <div
              class="text-center text-white/60 leading-relaxed [&>strong]:text-brand [&>strong]:font-semibold"
              data-aos="fade-up-sm"
              data-aos-delay="200"
              set:html={markdownify(amalgamy.intro)}
            />
          </div>
        </div>

        <div class="mb-4 row">
          <div class="lg:col-10 mx-auto">
            <p
              class="mb-2 text-xs font-semibold uppercase tracking-widest text-brand"
              data-aos="fade-up-sm"
              data-aos-delay="250"
            >
              Amalgamy closes this gap through three key capabilities
            </p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-10">
          {amalgamy.capabilities.map((cap, i) => (
            <div
              class="relative p-8 rounded-2xl border border-white/[0.08] bg-white/[0.03] overflow-hidden"
              data-aos="fade-up-sm"
              data-aos-delay={(i + 1) * 100}
            >
              <div class="absolute top-0 inset-x-0 h-[2px] bg-gradient-to-r from-brand/40 via-brand/80 to-brand/40" />
              <h3 class="mb-3 text-lg font-semibold text-white">{cap.title}</h3>
              <p class="text-sm text-white/50 leading-relaxed">{cap.text}</p>
            </div>
          ))}
        </div>

        <div class="text-center" data-aos="fade-up-sm" data-aos-delay="400">
          <a
            href={amalgamy.button.link}
            class="group inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-white rounded-full bg-brand border border-brand/80 shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_20px_rgba(36,171,157,0.15)] hover:shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_30px_rgba(36,171,157,0.25)] hover:bg-brand/90 transition-all duration-300"
          >
            {amalgamy.button.label}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}
  <!-- /Amalgamy -->

  <!-- Blueprint to Bluelight -->
  {blueprint && (
    <section class="section">
      <div class="container">
        <div class="justify-center row">
          <div class="lg:col-8">
            <h2
              class="pb-4 text-center"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(blueprint.title)}
            />
            <p
              class="text-center text-light leading-relaxed mb-6"
              data-aos="fade-up-sm"
              data-aos-delay="200"
            >
              {blueprint.description}
            </p>
            <div class="text-center" data-aos="fade-up-sm" data-aos-delay="300">
              <a
                href={blueprint.button.link}
                class="group inline-flex items-center gap-1 text-brand font-semibold hover:opacity-80 transition duration-300"
              >
                {blueprint.button.label}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}
  <!-- /Blueprint to Bluelight -->

  <!-- Built for where you are -->
  {tracks && (
    <section class="section bg-theme-light/40">
      <div class="container">
        <h2
          class="pb-8 text-center"
          data-aos="fade-up-sm"
          data-aos-delay="100"
          set:html={markdownify(tracks.title)}
        />
        <div class="grid gap-6 lg:grid-cols-2">
          <div
            class="relative p-8 lg:p-10 rounded-2xl border border-border/60 bg-white shadow-sm overflow-hidden"
            data-aos="fade-right-sm"
            data-aos-delay="200"
          >
            <div class="absolute top-0 inset-x-0 h-[2px] bg-gradient-to-r from-brand/40 via-brand/80 to-brand/40" />
            <h3 class="mb-4 text-xl font-semibold">{tracks.track_a.title}</h3>
            <p class="text-sm text-light leading-relaxed">{tracks.track_a.description}</p>
          </div>
          <div
            class="relative p-8 lg:p-10 rounded-2xl border border-border/60 bg-white shadow-sm overflow-hidden"
            data-aos="fade-left-sm"
            data-aos-delay="200"
          >
            <div class="absolute top-0 inset-x-0 h-[2px] bg-gradient-to-r from-brand/40 via-brand/80 to-brand/40" />
            <h3 class="mb-4 text-xl font-semibold">{tracks.track_b.title}</h3>
            <p class="text-sm text-light leading-relaxed">{tracks.track_b.description}</p>
          </div>
        </div>
      </div>
    </section>
  )}
  <!-- /Built for where you are -->

  <!-- Empower Your Teams -->
  {empower && (
    <section class="section">
      <div class="container">
        <div class="justify-center row">
          <div class="lg:col-8">
            <h2
              class="pb-4 text-center"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(empower.title)}
            />
            <div
              class="text-center text-light leading-relaxed mb-6"
              data-aos="fade-up-sm"
              data-aos-delay="200"
              set:html={markdownify(empower.description)}
            />
            {empower.button && (
              <div class="text-center" data-aos="fade-up-sm" data-aos-delay="300">
                <a
                  href={empower.button.link}
                  class="group inline-flex items-center gap-1 text-brand font-semibold hover:opacity-80 transition duration-300"
                >
                  {empower.button.label}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  )}
  <!-- /Empower Your Teams -->

  <!-- Sovereign Co-Op Framework -->
  {coop && (
    <section class="relative section bg-primary overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
      <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
      <div class="absolute -top-40 -right-40 w-[500px] h-[500px] rounded-full bg-brand/8 blur-3xl pointer-events-none" />
      <div class="absolute -bottom-40 -left-40 w-[400px] h-[400px] rounded-full bg-brand/5 blur-3xl pointer-events-none" />
      <div class="container relative z-10">
        <div class="justify-center mb-4 row">
          <div class="lg:col-8">
            <h2
              class="pb-2 text-center text-white"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(coop.title)}
            />
            {coop.subtitle && (
              <p
                class="pb-4 text-center text-lg text-brand font-semibold"
                data-aos="fade-up-sm"
                data-aos-delay="150"
              >
                {coop.subtitle}
              </p>
            )}
            <div
              class="text-center text-theme-light/70"
              data-aos="fade-up-sm"
              data-aos-delay="200"
              set:html={markdownify(coop.description)}
            />
          </div>
        </div>

        <div class="mb-4 row">
          <div class="lg:col-10 mx-auto">
            <p
              class="mb-2 text-xs font-semibold uppercase tracking-widest text-brand"
              data-aos="fade-up-sm"
              data-aos-delay="250"
            >
              The Network Ecosystem
            </p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-10">
          {coop.points.map((point, i) => (
            <div
              class="relative p-8 rounded-2xl border border-white/[0.08] bg-white/[0.03] overflow-hidden"
              data-aos="fade-up-sm"
              data-aos-delay={(i + 1) * 100}
            >
              <div class="absolute top-0 inset-x-0 h-[2px] bg-gradient-to-r from-brand/40 via-brand/80 to-brand/40" />
              <h3 class="mb-3 text-lg font-semibold text-white">{point.title}</h3>
              <p class="text-sm text-white/50 leading-relaxed">{point.text}</p>
            </div>
          ))}
        </div>

        {coop.button && (
          <div class="text-center" data-aos="fade-up-sm" data-aos-delay="400">
            <a
              href={coop.button.link}
              class="group inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-white rounded-full bg-brand border border-brand/80 shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_20px_rgba(36,171,157,0.15)] hover:shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_30px_rgba(36,171,157,0.25)] hover:bg-brand/90 transition-all duration-300"
            >
              {coop.button.label}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        )}
      </div>
    </section>
  )}
  <!-- /Sovereign Co-Op Framework -->

  <!-- CTA: Own Your AI Future -->
  {cta_section && (
    <section class="mx-4 overflow-hidden section">
      <div
        data-aos="fade-up"
        data-aos-delay="100"
        class="container relative px-8 py-12 text-white bg-primary sm:px-16 sm:py-14 lg:px-24 lg:py-20 rounded-xl overflow-hidden"
      >
        <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary rounded-xl"></div>
        <div class="absolute inset-0 opacity-[0.06] rounded-xl" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
        <div class="absolute -top-20 -right-20 w-[350px] h-[350px] rounded-full bg-brand/10 blur-3xl pointer-events-none" />

        <div class="absolute bottom-0 left-1/2 w-2/3 pointer-events-none" style="transform: translateY(50%);">
          <img
            src="/images/cta/cta-img-1.png"
            alt=""
            class="w-full cta-rotate-animation opacity-90"
            style="filter: sepia(1) hue-rotate(130deg) saturate(8) brightness(1);"
          />
        </div>
        <img
          src="/images/cta/cta-img-2.png"
          alt=""
          class="w-1/3 absolute top-[10%] -left-[10%] opacity-90 pointer-events-none"
          style="filter: sepia(1) hue-rotate(130deg) saturate(8) brightness(1);"
        />
        <img
          src="/images/cta/cta-img-2.png"
          alt=""
          class="w-1/3 absolute top-[10%] -right-[10%] opacity-90 pointer-events-none"
          style="filter: sepia(1) hue-rotate(130deg) saturate(8) brightness(1);"
        />

        <div class="relative z-10">
          <h2
            class="pb-4 text-center text-white"
            data-aos="fade-up-sm"
            data-aos-delay="200"
            set:html={markdownify(cta_section.title)}
          />
          <p
            class="mx-auto max-w-2xl pb-6 text-center text-white/60"
            data-aos="fade-up-sm"
            data-aos-delay="300"
            set:html={markdownify(cta_section.description)}
          />
          {cta_section.subtitle && (
            <p
              class="mx-auto max-w-md pb-8 text-center text-sm text-white/40"
              data-aos="fade-up-sm"
              data-aos-delay="350"
            >
              Start a structured engagement to define your deployment path from plan to operational capability.
            </p>
          )}
          <div
            class="w-fit mx-auto block"
            data-aos="fade-up-sm"
            data-aos-delay="400"
          >
            <a
              href={cta_section.button.link}
              class="group relative z-10 inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-white rounded-full bg-brand border border-brand/80 shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_20px_rgba(36,171,157,0.15)] hover:shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_30px_rgba(36,171,157,0.25)] hover:bg-brand/90 transition-all duration-300"
            >
              {cta_section.button.label}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  )}
  <!-- /CTA -->

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Amalgamy.ai",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Cloud",
    "description": "GPU-powered HPC platform for AI and machine learning workloads. Hardware orchestration for sovereign AI infrastructure.",
    "url": "https://amalgamy.ai",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD"
    },
    "creator": {
      "@type": "Organization",
      "name": "ThisWay Global",
      "url": "https://thiswayglobal.com"
    }
  })} />

  <style is:global>
    .hero-gradient-text {
      color: #fff;
    }
    .hero-gradient-text strong {
      color: #9ca3af;
      font-weight: inherit;
    }
  </style>
</Base>
