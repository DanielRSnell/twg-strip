---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import CallToAction from "@/partials/CallToAction.astro";
import Testimonial from "@/partials/Testimonial.astro";
import { getEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import { getSinglePage } from "@/lib/contentParser.astro";
import BlogCard from "@/components/BlogCard.astro";
import ServiceSlider from "@/components/homepage/ServiceSlider";
import HeroInfographic from "@/helpers/HeroInfographic";

const homepage = await getEntry("homepage", "-index");
const testimonial = await getEntry("sections", "testimonial");
const call_to_action = await getEntry("sections", "call-to-action");
const { banner, service, feature, about } = homepage.data;

const BLOG_FOLDER = "blog";
const postIndex = await getEntry(BLOG_FOLDER, "-index");
const { homepage_title, homepage_description } = postIndex.data;
const posts = await getSinglePage(BLOG_FOLDER);

---

<Base>
  <!-- Banner -->
  <section class="relative overflow-hidden bg-primary pt-[100px] pb-[80px] lg:pt-[120px] lg:pb-[100px]">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
    <div class="container relative z-10">
      <div class="items-center row gy-5">
        <div class="lg:col-7">
          <div
            class="inline-flex items-center gap-2 px-4 py-2 mb-8 text-sm font-medium text-white/90 rounded-full border border-white/[0.08] bg-white/[0.04] backdrop-blur-sm shadow-[0_0_20px_rgba(36,171,157,0.08)]"
            data-aos="fade-right-sm"
            data-aos-delay="50"
          >
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-brand shadow-[0_0_6px_rgba(36,171,157,0.6)]"></span>
            The Amalgamy.ai Platform by ThisWay Global
          </div>
          <h1
            class="mb-6 text-white"
            data-aos="fade-right-sm"
            data-aos-delay="100"
            set:html={markdownify(banner.title)}
          />
          <p
            class="mb-10 max-w-xl text-lg leading-relaxed text-white/60"
            data-aos="fade-right-sm"
            data-aos-delay="200"
            set:html={markdownify(banner.content)}
          />
          <div
            class="flex flex-wrap gap-4"
            data-aos="fade-right-sm"
            data-aos-delay="300"
          >
            {banner.button?.enable && (
              <a
                class="group relative inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-white rounded-full bg-brand border border-brand/80 shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_20px_rgba(36,171,157,0.15)] hover:shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_30px_rgba(36,171,157,0.25)] hover:bg-brand/90 transition-all duration-300"
                href={banner.button.link}
              >
                {banner.button.label}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            )}
            {banner.button_secondary?.enable && (
              <a
                class="group relative inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-white/90 rounded-full border border-white/[0.12] bg-white/[0.04] backdrop-blur-sm hover:bg-white/[0.08] hover:border-white/[0.2] transition-all duration-300"
                href={banner.button_secondary.link}
              >
                {banner.button_secondary.label}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            )}
          </div>
        </div>
        <div class="hidden lg:block lg:col-5">
          <HeroInfographic client:visible />
        </div>
      </div>
    </div>
  </section>
  <!-- /Banner -->


  <!-- service -->
  <section class="pb-0 section">
    <div class="container">
      <h2
        class="pb-8"
        data-aos="fade-right-sm"
        set:html={markdownify(service.title)}
      />
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          service.services.map((s, i: number) => (
            <div
              class="relative p-8 rounded-2xl border border-border/60 bg-white shadow-sm overflow-hidden"
              data-aos="fade-right-sm"
              data-aos-delay={i * 100}
            >
              <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-brand/60 via-brand to-brand/60" />
              <Icon name={s.image} class="mb-20 w-14 h-14" />
              <h3 class="mb-3 text-xl font-semibold" set:html={markdownify(s.title)} />
              <p class="mb-4 text-sm text-light leading-relaxed" set:html={markdownify(s.content)} />
              {s.button.enable && (
                <a
                  href={s.button.link}
                  class="flex gap-1 items-center transition duration-300 text-brand hover:opacity-80"
                >
                  Learn More <span class="sr-only">Details</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon icon-tabler icons-tabler-outline icon-tabler-arrow-right"
                  >
                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                    <path d="M5 12l14 0" />
                    <path d="M13 18l6 -6" />
                    <path d="M13 6l6 6" />
                  </svg>
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>
  <!-- service -->

  <!-- feature -->
  <section class="section">
    <div class="container">
      <div class="justify-center mb-10 row xl:mb-14">
        <div class="lg:col-8">
          <h2
            class="text-center"
            data-aos="fade-up-sm"
            data-aos-delay="100"
            set:html={markdownify(feature.title)}
          />
        </div>
        <div class="lg:col-6">
          <p
            class="text-center"
            data-aos="fade-up-sm"
            data-aos-delay="200"
            set:html={markdownify(feature.content)}
          />
        </div>
      </div>
      <div
        class="flex flex-col gap-10 justify-center md:flex-row lg:justify-between md:items-stretch"
      >
        <ServiceSlider feature={feature.features} client:visible />
      </div>
    </div>
  </section>
  <!-- feature -->

  <!-- review -->
  <section class="hidden section bg-primary">
    <div class="container text-white">
      <div class="pb-24 lg:pb-28">
        <div class="flex flex-col gap-10 justify-center">
          <div>
            <h2
              class="pb-4 text-center text-white"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(testimonial.data.homepage_title)}
            />
            <p
              class="mx-auto max-w-xl text-center text-theme-light/80"
              data-aos="fade-up-sm"
              data-aos-delay="200"
              set:html={markdownify(testimonial.data.content)}
            />
          </div>

          <Testimonial
            testimonials={testimonial.data.testimonials.slice(0, 3)}
          />

          <div class="inline-block text-center">
            <a href="/reviews" class="btn btn-outline-secondary">
              Read All Reviews
            </a>
          </div>
        </div>
      </div>
      <div class="pt-24 border-t lg:pt-28 border-border/20">
        <div
          class="justify-center items-center row md:justify-between gy-5 gx-4 xl:gx-5"
        >
          <div class="order-2 col-12 md:col-5 md:order-1">
            <div class="flex flex-col gap-6">
              <h2
                class="text-white"
                data-aos="fade-up-sm"
                data-aos-delay="100"
                set:html={markdownify(about.title)}
              />
              <p
                class="text-theme-light/80"
                data-aos="fade-up-sm"
                data-aos-delay="200"
                set:html={markdownify(about.content)}
              />
              <p
                class="text-theme-light/80"
                data-aos="fade-up-sm"
                data-aos-delay="300"
                set:html={markdownify(about.content_2)}
              />
              {
                about.button.enable && (
                  <div
                    class="inline-block"
                    data-aos="fade-up-sm"
                    data-aos-delay="400"
                  >
                    <a
                      href={about.button.link}
                      class="btn btn-outline-secondary"
                      set:html={about.button.label}
                    />
                  </div>
                )
              }
            </div>
          </div>
          <div
            class="order-1 col-12 md:col-6 md:order-2"
            data-aos="fade-up-sm"
            data-aos-delay="200"
          >
            <div
              class="p-8 rounded-xl border bg-tertiary/20 border-border/20 md:px-24 md:py-14"
            >
              <ImageMod
                class="mx-auto"
                src={about.image}
                width={0}
                height={435}
                alt={about.title}
                format="webp"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- review -->

  <!-- blog -->
  <section class="hidden pb-0 section">
    <div class="container">
      <div class="flex flex-col gap-14">
        <div class="justify-center row">
          <div class="lg:col-8">
            <h2
              class="pb-4 text-center"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(homepage_title!)}
            />
            <p
              class="text-center"
              data-aos="fade-up-sm"
              data-aos-delay="200"
              set:html={markdownify(homepage_description!)}
            />
          </div>
        </div>
        <div class="row g-4">
          {
            posts.map((post, i: number) => (
              <div
                class="relative sm:col-6 lg:col-4 group"
                data-aos="fade-up-sm"
                data-aos-delay={(i + 1) * 100}
              >
                <BlogCard post={post} />
              </div>
            ))
          }
        </div>
        <div class="inline-block text-center">
          <a class="btn btn-outline-primary" href="/blog">
            Read All Articles
          </a>
        </div>
      </div>
    </div>
  </section>
  <!-- blog -->

  <CallToAction call_to_action={call_to_action} />
</Base>


