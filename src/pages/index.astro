---
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { getEntry } from "astro:content";
import HeroInfographic from "@/helpers/HeroInfographic";
import ExternalLogo from "@/base/ExternalLogo.astro";

const homepage = await getEntry("homepage", "-index");
const { banner, social_proof, blueprint, tracks, coop, empower, cta_section } = homepage.data;
---

<Base>
  <!-- Banner -->
  <section class="relative overflow-hidden bg-primary pt-[100px] pb-[80px] lg:pt-[120px] lg:pb-[100px]">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
    <div class="container relative z-10">
      <div class="items-center row gy-5">
        <div class="lg:col-7">
          <h1
            class="mb-6 font-extrabold hero-gradient-text"
            data-aos="fade-right-sm"
            data-aos-delay="100"
            set:html={markdownify(banner.title)}
          />
          <div
            class="mb-10 max-w-xl text-lg leading-relaxed text-white/60 [&>p]:mb-4 [&>p:last-child]:mb-0"
            data-aos="fade-right-sm"
            data-aos-delay="200"
            set:html={markdownify(banner.content)}
          />
          <div
            class="flex flex-wrap gap-4"
            data-aos="fade-right-sm"
            data-aos-delay="300"
          >
            {banner.button?.enable && (
              <a
                class="group relative inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-white rounded-full bg-brand border border-brand/80 shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_20px_rgba(36,171,157,0.15)] hover:shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_30px_rgba(36,171,157,0.25)] hover:bg-brand/90 transition-all duration-300"
                href={banner.button.link}
              >
                {banner.button.label}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            )}
            {banner.button_secondary?.enable && (
              <a
                class="group relative inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-white/90 rounded-full border border-white/[0.12] bg-white/[0.04] backdrop-blur-sm hover:bg-white/[0.08] hover:border-white/[0.2] transition-all duration-300"
                href={banner.button_secondary.link}
              >
                {banner.button_secondary.label}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            )}
          </div>
        </div>
        <div class="hidden lg:block lg:col-5">
          <HeroInfographic client:visible />
        </div>
      </div>
    </div>
  </section>
  <!-- /Banner -->

  <!-- Social Proof -->
  {social_proof && (
    <section class="section">
      <div class="container">
        <div class="justify-center mb-8 row">
          <div class="lg:col-8">
            <h2
              class="pb-4 text-center"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(social_proof.title)}
            />
            <p
              class="text-center text-light"
              data-aos="fade-up-sm"
              data-aos-delay="200"
              set:html={markdownify(social_proof.subtitle)}
            />
          </div>
        </div>

        <div
          class="flex items-stretch justify-center mx-auto max-w-3xl rounded-xl border border-border/60 bg-white shadow-sm overflow-hidden divide-x divide-border/60 mb-8"
          data-aos="fade-up-sm"
          data-aos-delay="300"
        >
          {social_proof.logos.map((logo) => {
            const isTstc = logo.domain === "tstc.edu";
            return (
              <div class="flex-1 flex items-center justify-center py-6 px-5 hover:bg-theme-light/40 transition-colors duration-300">
                <ExternalLogo
                  domain={logo.domain}
                  name={logo.name}
                  height={isTstc ? 56 : 44}
                  width={isTstc ? 140 : 110}
                  class={`object-contain ${isTstc ? "max-h-14" : "max-h-11"}`}
                />
              </div>
            );
          })}
        </div>

        <div
          class="rounded-2xl border border-brand/20 bg-brand/[0.03] p-8 lg:p-10 text-center"
          data-aos="fade-up-sm"
          data-aos-delay="400"
        >
          <p class="mb-2 text-lg font-semibold text-dark" set:html={markdownify(social_proof.callout)} />
          {social_proof.callout_stats && (
            <p class="text-sm text-light" set:html={markdownify(social_proof.callout_stats)} />
          )}
        </div>

        <div
          class="mt-8 rounded-2xl bg-dark/95 border border-border/20 overflow-hidden flex items-center justify-center aspect-video relative"
          data-aos="fade-up-sm"
          data-aos-delay="500"
        >
          <div class="absolute inset-0 opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
          <div class="text-center relative z-10">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full border-2 border-brand/30 bg-brand/10 mb-4 hover:bg-brand/20 hover:border-brand/50 transition-all duration-300 cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-brand ml-1"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
            <p class="text-sm text-white/50">Video testimonial coming soon</p>
          </div>
        </div>
      </div>
    </section>
  )}
  <!-- /Social Proof -->

  <!-- Blueprint to Bluelight -->
  {blueprint && (
    <section class="section pt-0">
      <div class="container">
        <div class="relative rounded-2xl border border-border/60 bg-white shadow-sm overflow-hidden p-8 lg:p-12">
          <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-brand/60 via-brand to-brand/60" />
          <div class="row gy-5 items-start">
            <div class="lg:col-5">
              <h2
                class="mb-6"
                data-aos="fade-right-sm"
                data-aos-delay="100"
                set:html={markdownify(blueprint.title)}
              />
              <p
                class="text-light leading-relaxed"
                data-aos="fade-right-sm"
                data-aos-delay="200"
                set:html={markdownify(blueprint.description)}
              />
            </div>
            <div class="lg:col-7">
              <div class="mb-5 text-xs font-semibold uppercase tracking-widest text-brand" data-aos="fade-left-sm" data-aos-delay="100">
                We provide:
              </div>
              <div class="flex flex-col gap-4">
                {blueprint.points.map((point, i) => (
                  <div
                    class="flex gap-4 items-start p-4 rounded-xl bg-theme-light/40 border border-border/30"
                    data-aos="fade-left-sm"
                    data-aos-delay={(i + 1) * 100}
                  >
                    <div class="mt-0.5 flex-shrink-0 w-7 h-7 rounded-full bg-brand/10 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand"><path d="M20 6 9 17l-5-5"/></svg>
                    </div>
                    <p class="text-sm text-dark leading-relaxed">
                      <strong>{point.title}</strong> {point.text}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="mt-8 pt-8 border-t border-border/40">
            <p
              class="text-light leading-relaxed"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(blueprint.footer)}
            />
            <div class="mt-4" data-aos="fade-up-sm" data-aos-delay="200">
              <a
                href={blueprint.button.link}
                class="group inline-flex items-center gap-1 text-brand font-semibold hover:opacity-80 transition duration-300"
              >
                {blueprint.button.label}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}
  <!-- /Blueprint to Bluelight -->

  <!-- Built for where you are -->
  {tracks && (
    <section class="section bg-theme-light/40">
      <div class="container">
        <h2
          class="pb-8 text-center"
          data-aos="fade-up-sm"
          data-aos-delay="100"
          set:html={markdownify(tracks.title)}
        />
        <div class="grid gap-4 lg:grid-cols-2">
          <div
            data-aos="fade-right-sm"
            data-aos-delay="200"
          >
            <div class="relative h-full p-8 lg:p-10 rounded-2xl border border-border/60 bg-white shadow-sm overflow-hidden">
              <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-brand/60 via-brand to-brand/60" />
              <h3 class="mb-4 text-xl font-semibold" set:html={markdownify(tracks.track_a.title)} />
              <div class="mb-6 text-sm text-light leading-relaxed" set:html={markdownify(tracks.track_a.description)} />
              <div class="flex flex-col gap-4">
                {tracks.track_a.points.map((point) => (
                  <div class="flex gap-3 items-start">
                    <div class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-brand/10 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-brand"><path d="M20 6 9 17l-5-5"/></svg>
                    </div>
                    <p class="text-sm text-dark leading-relaxed">
                      <strong>{point.title}</strong> {point.text}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div
            data-aos="fade-left-sm"
            data-aos-delay="200"
          >
            <div class="relative h-full p-8 lg:p-10 rounded-2xl border border-border/60 bg-white shadow-sm overflow-hidden">
              <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-brand/60 via-brand to-brand/60" />
              <h3 class="mb-4 text-xl font-semibold" set:html={markdownify(tracks.track_b.title)} />
              <div class="mb-6 text-sm text-light leading-relaxed" set:html={markdownify(tracks.track_b.description)} />
              <div class="flex flex-col gap-4">
                {tracks.track_b.points.map((point) => (
                  <div class="flex gap-3 items-start">
                    <div class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-brand/10 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-brand"><path d="M20 6 9 17l-5-5"/></svg>
                    </div>
                    <p class="text-sm text-dark leading-relaxed">
                      <strong>{point.title}</strong> {point.text}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}
  <!-- /Built for where you are -->

  <!-- Sovereign Co-Op Framework -->
  {coop && (
    <section class="relative section bg-primary overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
      <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
      <div class="absolute -top-40 -right-40 w-[500px] h-[500px] rounded-full bg-brand/8 blur-3xl pointer-events-none" />
      <div class="absolute -bottom-40 -left-40 w-[400px] h-[400px] rounded-full bg-brand/5 blur-3xl pointer-events-none" />
      <div class="container relative z-10">
        <div class="justify-center mb-8 row">
          <div class="lg:col-8">
            <h2
              class="pb-4 text-center text-white"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(coop.title)}
            />
            <div
              class="text-center text-theme-light/70"
              data-aos="fade-up-sm"
              data-aos-delay="200"
              set:html={markdownify(coop.description)}
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {coop.points.map((point, i) => (
            <div
              class="relative p-8 rounded-2xl border border-white/[0.08] bg-white/[0.03] overflow-hidden"
              data-aos="fade-up-sm"
              data-aos-delay={(i + 1) * 100}
            >
              <div class="absolute top-0 inset-x-0 h-[2px] bg-gradient-to-r from-brand/40 via-brand/80 to-brand/40" />
              <h3 class="mb-3 text-lg font-semibold text-white">{point.title}</h3>
              <p class="text-sm text-white/50 leading-relaxed">{point.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
  <!-- /Sovereign Co-Op Framework -->

  <!-- Empower Your Team -->
  {empower && (
    <section class="section">
      <div class="container">
        <div class="justify-center mb-8 row">
          <div class="lg:col-8">
            <h2
              class="pb-4 text-center"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(empower.title)}
            />
            <p
              class="text-center text-light"
              data-aos="fade-up-sm"
              data-aos-delay="200"
              set:html={markdownify(empower.description)}
            />
          </div>
        </div>

        <div class="row gy-5 items-stretch" data-aos="fade-up-sm" data-aos-delay="300">
          <div class="lg:col-5">
            <div class="h-full rounded-2xl bg-dark/95 border border-border/20 overflow-hidden flex items-center justify-center relative">
              <div class="absolute inset-0 opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
              <div class="text-center p-8 relative z-10">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full border-2 border-brand/30 bg-brand/10 mb-4 hover:bg-brand/20 hover:border-brand/50 transition-all duration-300 cursor-pointer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-brand ml-1"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </div>
                <p class="text-sm text-white/50">Video coming soon</p>
              </div>
            </div>
          </div>
          <div class="lg:col-7">
            <div class="flex flex-col gap-4 lg:pl-2">
              {empower.points.map((point, i) => (
                <div
                  class="relative p-6 rounded-xl border border-border/60 bg-white shadow-sm overflow-hidden"
                  data-aos="fade-left-sm"
                  data-aos-delay={(i + 1) * 100}
                >
                  <div class="absolute left-0 inset-y-0 w-1 bg-gradient-to-b from-brand/60 via-brand to-brand/60" />
                  <h3 class="text-base font-semibold mb-1 pl-3">{point.title}</h3>
                  <p class="text-sm text-light leading-relaxed pl-3">{point.text}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}
  <!-- /Empower Your Team -->

  <!-- CTA: Own Your AI Future -->
  {cta_section && (
    <section class="mx-4 overflow-hidden section">
      <div
        data-aos="fade-up"
        data-aos-delay="100"
        class="container relative px-8 py-12 text-white bg-primary sm:px-16 sm:py-14 lg:px-24 lg:py-20 rounded-xl overflow-hidden"
      >
        <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary rounded-xl"></div>
        <div class="absolute inset-0 opacity-[0.06] rounded-xl" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
        <div class="absolute -top-20 -right-20 w-[350px] h-[350px] rounded-full bg-brand/10 blur-3xl pointer-events-none" />

        <div class="absolute bottom-0 left-1/2 w-2/3 pointer-events-none" style="transform: translateY(50%);">
          <img
            src="/images/cta/cta-img-1.png"
            alt=""
            class="w-full cta-rotate-animation opacity-90"
            style="filter: sepia(1) hue-rotate(130deg) saturate(8) brightness(1);"
          />
        </div>
        <img
          src="/images/cta/cta-img-2.png"
          alt=""
          class="w-1/3 absolute top-[10%] -left-[10%] opacity-90 pointer-events-none"
          style="filter: sepia(1) hue-rotate(130deg) saturate(8) brightness(1);"
        />
        <img
          src="/images/cta/cta-img-2.png"
          alt=""
          class="w-1/3 absolute top-[10%] -right-[10%] opacity-90 pointer-events-none"
          style="filter: sepia(1) hue-rotate(130deg) saturate(8) brightness(1);"
        />

        <div class="relative z-10">
          <h2
            class="pb-4 text-center text-white"
            data-aos="fade-up-sm"
            data-aos-delay="200"
            set:html={markdownify(cta_section.title)}
          />

          <p
            class="mx-auto max-w-2xl pb-8 text-center text-white/60"
            data-aos="fade-up-sm"
            data-aos-delay="300"
            set:html={markdownify(cta_section.description)}
          />

          <div class="mx-auto max-w-2xl rounded-2xl border border-white/[0.06] bg-white/[0.03] backdrop-blur-sm p-8 lg:p-10 mb-10"
            data-aos="fade-up-sm"
            data-aos-delay="350"
          >
          <h3 class="pb-1 text-center text-lg font-semibold text-white">
            {cta_section.subtitle}
          </h3>
          <p class="pb-8 text-center text-xs text-white/40">
            Start a structured engagement to define your deployment path:
          </p>

          <div class="relative">
            <div class="absolute top-[7px] left-0 right-0 h-[2px] bg-gradient-to-r from-brand/0 via-brand/40 to-brand/0" />
            <div class="flex justify-between relative">
              {cta_section.steps.map((step, i) => (
                <div class="flex flex-col items-center" style={`width: ${100 / cta_section.steps.length}%`}>
                  <div class="relative z-10 w-4 h-4 rounded-full border-2 border-brand bg-primary shadow-[0_0_8px_rgba(36,171,157,0.3)]">
                    <div class="absolute inset-[3px] rounded-full bg-brand" />
                  </div>
                  <div class="mt-4 text-center">
                    <p class="text-sm font-semibold text-white">{step.label}</p>
                    <p class="mt-1 text-xs text-white/35 leading-relaxed max-w-[160px] mx-auto">{step.text}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          </div>

          <div
            class="w-fit mx-auto block"
            data-aos="fade-up-sm"
            data-aos-delay="500"
          >
            <a
              href={cta_section.button.link}
              class="group relative z-10 inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-white rounded-full bg-brand border border-brand/80 shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_20px_rgba(36,171,157,0.15)] hover:shadow-[0_1px_2px_rgba(0,0,0,0.2),0_0_30px_rgba(36,171,157,0.25)] hover:bg-brand/90 transition-all duration-300"
            >
              {cta_section.button.label}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  )}
  <!-- /CTA -->

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Amalgamy.ai",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Cloud",
    "description": "GPU-powered HPC platform for AI and machine learning workloads. Hardware orchestration for sovereign AI infrastructure.",
    "url": "https://amalgamy.ai",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD"
    },
    "creator": {
      "@type": "Organization",
      "name": "ThisWay Global",
      "url": "https://thiswayglobal.com"
    }
  })} />

  <style is:global>
    .hero-gradient-text,
    .hero-gradient-text * {
      background: linear-gradient(to right, #fff, #24ab9d);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
  </style>
</Base>
