---
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { getEntry } from "astro:content";
const homepage = await getEntry("homepage", "-index");
const { banner, blueprint, amalgamy, tracks, empower, coop, social_proof, cta_section } = homepage.data;

const infographicIcons = {
  current: [
    '<path d="M21 5H3a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2z"/><path d="M7 10h0"/><path d="M12 10h0"/><path d="M17 10h0"/><path d="M7 14h0"/><path d="M12 14h0"/>',
    '<path d="M16 3h5v5"/><path d="M8 3H3v5"/><path d="M12 22v-8.3a4 4 0 0 0-1.172-2.872L3 3"/><path d="m15 9 6-6"/>',
    '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" y1="11" x2="22" y2="11"/><line x1="19.5" y1="8.5" x2="19.5" y2="13.5"/>',
    '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  ],
  solution: [
    '<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
    '<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>',
    '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
    '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  ],
  destination: [
    '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>',
    '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
    '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
    '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  ],
};
---

<Base>
  <!-- Banner -->
  <section class="relative overflow-hidden bg-primary min-h-[58vh] lg:min-h-[66vh] flex flex-col">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#0d1117] to-primary"></div>
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot; fill=&quot;none&quot;/%3E%3C/svg%3E');"></div>
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-brand/[0.04] blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] rounded-full bg-[#5969FC]/[0.03] blur-3xl pointer-events-none"></div>

    <!-- Unicorn Studio animated background (perf-tuned: half-res, 1x DPI, 30fps, no mouse, off on mobile) -->
    <div class="absolute inset-0 pointer-events-none unicorn-hero-bg" aria-hidden="true">
      <div
        data-us-project="FixNvEwvWwbu3QX9qC3F"
        data-us-scale="0.5"
        data-us-dpi="1"
        data-us-fps="30"
        data-us-disablemouse="true"
        data-us-disablemobile="true"
        data-us-lazyload="true"
        data-us-production="true"
      ></div>
    </div>

    <!-- Hero two-column layout -->
    <div class="relative z-10 mt-auto pt-[120px] pb-12 lg:pb-16 mx-auto w-full max-w-[1600px] px-6 lg:px-16">
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-28">

        <!-- Left: Title (top) + Quote (bottom), justified between -->
        <div class="lg:w-[55%] flex flex-col justify-between gap-10 lg:gap-0">
          <!-- Title block -->
          <div>
            <p
              class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-white/40"
              data-aos="fade-up-sm"
              data-aos-delay="50"
            >
              Sovereign AI Infrastructure
            </p>
            <h1
              class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-[1.05] tracking-tight capitalize"
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(banner.title)}
            />
          </div>

          <!-- Quote block (pushed to bottom on desktop) -->
          {social_proof?.case_study?.quote && (
            <div data-aos="fade-up-sm" data-aos-delay="300">
              <div class="h-px bg-gradient-to-r from-white/10 via-white/6 to-transparent mb-8"></div>
              <div class="flex items-start gap-5">
                <div class="shrink-0 w-14 h-14 rounded-full bg-white/10 border border-white/10 overflow-hidden">
                  <img src="/images/team-members/brandon-creighton.webp" alt="Brandon Creighton" class="w-full h-full object-cover" />
                </div>
                <div>
                  <blockquote class="relative mb-3 pl-5 border-l-2 border-brand/30">
                    <p class="text-sm lg:text-base text-white/60 leading-relaxed italic">
                      &ldquo;{social_proof.case_study.quote}&rdquo;
                    </p>
                  </blockquote>
                  <p class="pl-5 text-xs font-semibold text-brand/50 tracking-wide">{social_proof.case_study.attribution}</p>
                </div>
              </div>
            </div>
          )}
        </div>

        <!-- Right: Prose content + CTA -->
        <div class="lg:w-[45%] flex flex-col justify-end">
          <div
            class="prose prose-invert prose-lg max-w-none mb-10 [&>p]:text-white/50 [&>p]:leading-relaxed [&>p]:mb-5 [&>p:last-child]:mb-0 [&>p:first-child]:text-xl [&>p:first-child]:text-white/70 [&>p:first-child]:font-medium"
            data-aos="fade-up-sm"
            data-aos-delay="200"
            set:html={markdownify(banner.content, true)}
          />
          <div
            class="flex flex-wrap gap-4"
            data-aos="fade-up-sm"
            data-aos-delay="300"
          >
            {banner.button?.enable && (
              <a
                class="group inline-flex items-center gap-3 px-7 py-3.5 text-sm font-semibold text-white bg-brand/15 border border-brand/30 backdrop-blur-sm rounded hover:bg-brand/25 hover:border-brand/50 transition-all duration-300 tracking-wide uppercase shadow-[0_0_20px_rgba(36,171,157,0.1)] hover:shadow-[0_0_30px_rgba(36,171,157,0.2)]"
                href={banner.button.link}
              >
                {banner.button.label}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            )}
          </div>
        </div>

      </div>
    </div>
  </section>
  <!-- /Banner -->

  <!-- Unicorn Studio loader (deferred off the critical path; skipped for reduced-motion) -->
  <script is:inline>
    (function () {
      // Honor reduced-motion: don't load the WebGL background at all.
      if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      if (window.UnicornStudio) return;
      window.UnicornStudio = { isInitialized: false };

      function loadUnicorn() {
        var s = document.createElement("script");
        s.src = "https://cdn.jsdelivr.net/gh/hiunicornstudio/unicornstudio.js@v1.4.29/dist/unicornStudio.umd.js";
        s.async = true;
        s.onload = function () {
          if (!window.UnicornStudio.isInitialized) {
            UnicornStudio.init();
            window.UnicornStudio.isInitialized = true;
          }
        };
        (document.head || document.body).appendChild(s);
      }

      // Defer to idle time so the ~150KB script + WebGL init never blocks first paint / LCP.
      if ("requestIdleCallback" in window) {
        requestIdleCallback(loadUnicorn, { timeout: 3000 });
      } else {
        window.addEventListener("load", loadUnicorn);
      }
    })();
  </script>

  <!-- Border Grid Content Wrapper -->
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(60px,1fr)_minmax(0,1200px)_minmax(60px,1fr)] border-t border-black/[0.08]">

    <!-- Left Gutter (patterned) -->
    <div class="hidden lg:block border-r border-black/[0.08] bg-theme-light/40 gutter-grid"></div>

    <!-- Center Content (solid) -->
    <div class="bg-body">

      <!-- Sovereign AI Blueprint -->
      {blueprint && (
        <div class="border-b border-black/[0.08]">
          <!-- Section Header -->
          <div class="border-b border-black/[0.08] py-10 lg:py-14 px-6 lg:px-12">
            <div class="mb-4" data-aos="fade-up-sm" data-aos-delay="50">
              <span class="inline-flex items-center gap-2 px-3 py-1 border border-black/[0.12] text-dark/60 text-xs font-semibold uppercase tracking-widest">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                Blueprint
              </span>
            </div>
            <h2 class="pb-4 text-3xl lg:text-4xl font-bold" data-aos="fade-up-sm" data-aos-delay="100" set:html={markdownify(blueprint.title)} />
            <p class="max-w-2xl text-light leading-relaxed text-lg" data-aos="fade-up-sm" data-aos-delay="200">{blueprint.description}</p>
          </div>

          <!-- Infographic Grid -->
          <!-- Desktop -->
          <div class="hidden lg:block">
            <!-- Column Headers -->
            <div class="grid grid-cols-3 divide-x divide-black/[0.08] border-b border-black/[0.08]">
              <div class="py-3.5 px-6 text-center">
                <p class="text-xs font-bold uppercase tracking-widest text-dark/40">Current State</p>
              </div>
              <div class="py-3.5 px-6 text-center bg-[#7c3aed]/[0.03]">
                <p class="text-xs font-bold uppercase tracking-widest text-[#7c3aed]">Sovereign AI Blueprint</p>
              </div>
              <div class="py-3.5 px-6 text-center bg-brand/[0.03]">
                <p class="text-xs font-bold uppercase tracking-widest text-brand">Destination</p>
              </div>
            </div>
            <!-- Rows -->
            {blueprint.infographic.map((row, i) => (
              <div class="grid grid-cols-3 divide-x divide-black/[0.08] border-b border-black/[0.08] last:border-b-0" data-aos="fade-up-sm" data-aos-delay={100 + i * 60}>
                <div class="py-5 px-6 flex items-center gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-dark/30" set:html={infographicIcons.current[i]} />
                  <span class="text-sm text-dark/60">{row.current}</span>
                </div>
                <div class="py-5 px-6 flex items-center gap-3 bg-[#7c3aed]/[0.03]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-[#7c3aed]" set:html={infographicIcons.solution[i]} />
                  <span class="text-sm font-medium text-[#7c3aed]">{row.solution}</span>
                </div>
                <div class="py-5 px-6 flex items-center gap-3 bg-brand/[0.03]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-brand" set:html={infographicIcons.destination[i]} />
                  <span class="text-sm font-medium text-brand">{row.destination}</span>
                </div>
              </div>
            ))}
          </div>
          <!-- Mobile -->
          <div class="lg:hidden divide-y divide-black/[0.08]">
            {blueprint.infographic.map((row, i) => (
              <div class="py-5 px-6" data-aos="fade-up-sm" data-aos-delay={100 + i * 60}>
                <div class="flex items-center gap-2 mb-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-dark/30" set:html={infographicIcons.current[i]} />
                  <span class="text-xs text-dark/40">{row.current}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-dark/20 mx-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  <span class="text-xs font-medium text-[#7c3aed]">{row.solution}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-dark/20 mx-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  <span class="text-xs font-medium text-brand">{row.destination}</span>
                </div>
              </div>
            ))}
          </div>

          <!-- Button Row -->
          <div class="border-t border-black/[0.08] py-6 px-6 lg:px-12 text-center" data-aos="fade-up-sm">
            <a href={blueprint.button.link} class="group inline-flex items-center gap-2 px-6 py-2.5 text-sm font-semibold border border-black/[0.15] hover:border-black/[0.3] hover:bg-black/[0.02] transition-all duration-200">
              {blueprint.button.label}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      )}

      <!-- Connector Statement: Blueprint -> Amalgamy -->
      <div class="border-b border-black/[0.08] py-14 lg:py-20 px-6 lg:px-12" data-aos="fade-up-sm">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-2xl lg:text-3xl font-bold text-dark leading-snug">
            The Sovereign AI Blueprint is the map. <span class="text-brand">Amalgamy</span> is the control layer that makes it operational.
          </p>
        </div>
      </div>

      <!-- Amalgamy -->
      {amalgamy && (
        <div class="border-b border-black/[0.08]">
          <!-- Section Header -->
          <div class="border-b border-black/[0.08] py-10 lg:py-14 px-6 lg:px-12">
            <div class="mb-4" data-aos="fade-up-sm" data-aos-delay="50">
              <span class="inline-flex items-center gap-2 px-3 py-1 border border-black/[0.12] text-dark/60 text-xs font-semibold uppercase tracking-widest">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                Platform
              </span>
            </div>
            <h2 class="pb-4 text-3xl lg:text-4xl font-bold" data-aos="fade-up-sm" data-aos-delay="100" set:html={markdownify(amalgamy.title)} />
            <div class="max-w-3xl text-light leading-relaxed text-lg [&>strong]:text-dark [&>strong]:font-semibold [&>p]:mb-4 [&>p:last-child]:mb-0" data-aos="fade-up-sm" data-aos-delay="200" set:html={markdownify(amalgamy.intro, true)} />
          </div>

          <!-- Capabilities Label -->
          <div class="border-b border-black/[0.08] py-3 px-6 lg:px-12" data-aos="fade-up-sm">
            <p class="text-xs font-semibold uppercase tracking-widest text-dark/40">Core capabilities</p>
          </div>

          <!-- Capabilities Grid -->
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 max-sm:divide-y sm:divide-x divide-black/[0.08]">
            {amalgamy.capabilities.map((cap, i) => (
              <div class="py-8 px-6 lg:px-8" data-aos="fade-up-sm" data-aos-delay={(i + 1) * 80}>
                <h3 class="mb-3 text-base font-semibold">{cap.title}</h3>
                <p class="text-sm text-light leading-relaxed">{cap.text}</p>
              </div>
            ))}
          </div>

          <!-- Button Row -->
          <div class="border-t border-black/[0.08] py-6 px-6 lg:px-12 text-center" data-aos="fade-up-sm">
            <a href={amalgamy.button.link} class="group inline-flex items-center gap-2 px-6 py-2.5 text-sm font-semibold border border-black/[0.15] hover:border-black/[0.3] hover:bg-black/[0.02] transition-all duration-200">
              {amalgamy.button.label}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      )}

      <!-- Built for every path -->
      {tracks && (
        <div class="border-b border-black/[0.08]">
          <!-- Section Header -->
          <div class="border-b border-black/[0.08] py-10 lg:py-14 px-6 lg:px-12 text-center">
            <div class="mb-4" data-aos="fade-up-sm" data-aos-delay="50">
              <span class="inline-flex items-center gap-2 px-3 py-1 border border-black/[0.12] text-dark/60 text-xs font-semibold uppercase tracking-widest">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                Deployment Paths
              </span>
            </div>
            <h2 class="text-3xl lg:text-4xl font-bold" data-aos="fade-up-sm" data-aos-delay="100" set:html={markdownify(tracks.title)} />
          </div>

          <!-- Audiences -->
          {tracks.audiences && (
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 max-sm:divide-y sm:divide-x divide-black/[0.08] border-b border-black/[0.08]">
              {tracks.audiences.map((aud, i) => (
                <div class="py-6 px-6" data-aos="fade-up-sm" data-aos-delay={(i + 1) * 60}>
                  <p class="text-sm font-semibold text-brand mb-2">{aud.title}</p>
                  <p class="text-sm text-light leading-relaxed">{aud.text}</p>
                </div>
              ))}
            </div>
          )}

          <!-- Two Tracks -->
          <div class="grid lg:grid-cols-2 max-lg:divide-y lg:divide-x divide-black/[0.08]">
            <div class="py-10 lg:py-14 px-6 lg:px-10" data-aos="fade-up-sm" data-aos-delay="100">
              <div class="w-10 h-10 border border-black/[0.1] flex items-center justify-center text-dark/40 mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><polyline points="21 3 21 9 15 9"/></svg>
              </div>
              <h3 class="mb-3 text-xl font-semibold">{tracks.track_a.title}</h3>
              <p class="text-sm text-light leading-relaxed">{tracks.track_a.description}</p>
            </div>
            <div class="py-10 lg:py-14 px-6 lg:px-10" data-aos="fade-up-sm" data-aos-delay="200">
              <div class="w-10 h-10 border border-black/[0.1] flex items-center justify-center text-dark/40 mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              </div>
              <h3 class="mb-3 text-xl font-semibold">{tracks.track_b.title}</h3>
              <p class="text-sm text-light leading-relaxed">{tracks.track_b.description}</p>
            </div>
          </div>

          <!-- Button Row -->
          {tracks.button && (
            <div class="border-t border-black/[0.08] py-6 px-6 lg:px-12 text-center" data-aos="fade-up-sm">
              <a href={tracks.button.link} class="group inline-flex items-center gap-2 px-6 py-2.5 text-sm font-semibold border border-black/[0.15] hover:border-black/[0.3] hover:bg-black/[0.02] transition-all duration-200">
                {tracks.button.label}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          )}
        </div>
      )}

      <!-- Empower Your Teams -->
      {empower && (
        <div class="border-b border-black/[0.08]">
          <div class="grid lg:grid-cols-2 max-lg:divide-y lg:divide-x divide-black/[0.08]">
            <!-- Left: Content -->
            <div class="py-10 lg:py-14 px-6 lg:px-12">
